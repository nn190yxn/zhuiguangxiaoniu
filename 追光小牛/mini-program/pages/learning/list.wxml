<view class="container">
  <!-- Header Card with Points -->
  <view class="header-card">
    <view class="points-info">
      <text class="points-label">我的积分</text>
      <text class="points-value">{{totalPoints}}</text>
    </view>
    <view class="checkin-btn {{todayChecked ? 'checked' : ''}}" bindtap="doCheckin">
      <text class="checkin-text">{{todayChecked ? '已签到' : '签到'}}</text>
      <text class="checkin-points" wx:if="{{!todayChecked}}">+5</text>
    </view>
  </view>

  <!-- Quick Entry Section -->
  <view class="quick-entry">
    <view class="quick-entry-item" bindtap="goToPolicy">
      <view class="quick-entry-icon policy">📋</view>
      <view class="quick-entry-text">
        <view class="quick-entry-title">制度学习</view>
        <view class="quick-entry-desc">查看公司制度</view>
      </view>
    </view>
    <view class="quick-entry-item" bindtap="goToKnowledge">
      <view class="quick-entry-icon knowledge">🧠</view>
      <view class="quick-entry-text">
        <view class="quick-entry-title">通用知识</view>
        <view class="quick-entry-desc">体测/感统/工作标准</view>
      </view>
    </view>
  </view>

  <!-- Common Knowledge Section -->
  <view class="section-header">
    <text class="section-title">通用知识</text>
    <text class="section-more" bindtap="goToKnowledge">查看全部 →</text>
  </view>

  <scroll-view scroll-x class="knowledge-scroll" enable-flex>
    <view
      class="knowledge-card"
      wx:for="{{commonKnowledge}}"
      wx:key="id"
      bindtap="goToKnowledgeDetail"
      data-id="{{item.id}}"
    >
      <view class="knowledge-card-title">{{item.title}}</view>
      <view class="knowledge-card-desc">{{item.summary}}</view>
      <view class="knowledge-card-tags">
        <text class="tag">公共</text>
      </view>
    </view>
  </scroll-view>

  <!-- Course Section -->
  <view class="section-header" style="margin-top: 16px;">
    <text class="section-title">课程学习</text>
  </view>

  <view class="category-tabs">
    <scroll-view scroll-x class="scroll-tabs">
      <view
        class="tab-item {{selectedCategoryId === 0 ? 'active' : ''}}"
        bindtap="selectCategory"
        data-id="0"
      >全部</view>
      <view
        class="tab-item {{selectedCategoryId === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="selectCategory"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </scroll-view>
  </view>

  <view class="course-list">
    <view
      class="course-card {{item.is_completed ? 'completed' : ''}}"
      wx:for="{{courses}}"
      wx:key="id"
      bindtap="goToCourse"
      data-id="{{item.id}}"
    >
      <view class="course-cover" style="background-image: url('{{item.cover_image}}')">
        <view class="cover-overlay">
          <text class="status-text {{item.is_completed ? 'completed' : ''}}">
            {{item.is_completed ? '已完成' : (item.is_started ? '学习中' : '未开始')}}
          </text>
        </view>
        <view class="required-tag" wx:if="{{item.is_required}}">必修</view>
      </view>
      <view class="course-info">
        <view class="course-title">{{item.title}}</view>
        <view class="course-meta">
          <text class="category">{{item.category_name}}</text>
          <text class="duration">{{item.duration}}分钟</text>
        </view>
        <view class="course-footer">
          <text class="points-reward">+{{item.points_reward}}积分</text>
          <text class="difficulty difficulty-{{item.difficulty}}">
            {{['', '初级', '中级', '高级'][item.difficulty]}}
          </text>
        </view>
        <view class="progress-bar" wx:if="{{item.is_started && !item.is_completed}}">
          <view class="progress-fill" style="width: {{item.user_progress || 0}}%"></view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{courses.length === 0 && !loading}}">
      <text>暂无课程</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>