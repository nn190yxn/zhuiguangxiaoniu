.lesson-header {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.lesson-title {
  font-size: 18px;
  font-weight: 600;
  color: #1f1a17;
  flex: 1;
}

.lesson-duration {
  font-size: 13px;
  color: #9a958e;
  margin-left: 12px;
}

.lesson-content {
  margin: 0 16px;
}

.video-player {
  width: 100%;
  border-radius: 12px;
  background: #000;
}

.audio-player {
  width: 100%;
  padding: 20px;
  background: #ffffff;
  border-radius: 12px;
  margin-bottom: 16px;
}

.lesson-text {
  background: #ffffff;
  border-radius: 16px;
  padding: 20px;
  margin-top: 16px;
  font-size: 15px;
  line-height: 1.8;
  color: #1f1a17;
}

.lesson-text rich-text {
  display: block;
}

.lesson-nav {
  display: flex;
  gap: 12px;
  padding: 16px;
  margin-top: 20px;
}

.nav-btn {
  flex: 1;
  height: 48px;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn.prev {
  background: rgba(0,0,0,0.05);
  color: #6b625c;
}

.nav-btn.prev.disabled {
  opacity: 0.5;
}

.nav-btn.next {
  background: #ff6b35;
  color: #ffffff;
}

.nav-btn.next.completed {
  background: #4caf50;
}