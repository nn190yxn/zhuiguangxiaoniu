.container {
  padding: 16px;
  background: #f5f3f0;
  min-height: 100vh;
}

.dimension-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
  overflow-x: auto;
  padding-bottom: 8px;
}

.tab-item {
  padding: 8px 16px;
  background: #fff;
  border-radius: 20px;
  font-size: 14px;
  color: #6b625c;
  white-space: nowrap;
  border: 1px solid #e8e5e0;
}

.tab-item.active {
  background: #ff6b35;
  color: #fff;
  border-color: #ff6b35;
}

.loading {
  text-align: center;
  padding: 40px;
  color: #6b625c;
}

.script-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.script-card {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
}

.script-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.script-name {
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
}

.script-code {
  font-size: 12px;
  color: #9a958e;
}

.script-preview {
  font-size: 14px;
  color: #6b625c;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8px;
}

.script-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.keyword-tag {
  padding: 2px 8px;
  background: #f5f3f0;
  border-radius: 8px;
  font-size: 12px;
  color: #6b625c;
}

.empty {
  text-align: center;
  padding: 40px;
  color: #9a958e;
}
