page {
  background: #ff6b35;
}
.result-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}
.result-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 50rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}
.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: #4caf50;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin: 0 auto 30rpx;
}
.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}
.success-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
.home-btn {
  margin-top: 60rpx;
  background: #fff;
  color: #ff6b35;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 80rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
}
