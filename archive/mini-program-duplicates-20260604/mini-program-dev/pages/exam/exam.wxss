.container {
  min-height: 100vh;
  background: #f5f3f0;
  padding-bottom: 100px;
}

/* 考试信息栏 */
.exam-info-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: #ffffff;
  border-bottom: 1px solid #eee6dc;
  position: sticky;
  top: 0;
  z-index: 10;
}

.exam-timer {
  font-size: 16px;
  font-weight: 700;
  color: #ff6b35;
}

.exam-progress {
  font-size: 14px;
  color: #6b625c;
  font-weight: 600;
}

/* 答题区域 */
.exam-content {
  padding: 16px;
}

.question-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 8px 24px rgba(60, 42, 28, 0.06);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.question-type-tag {
  font-size: 12px;
  font-weight: 600;
  color: #ff6b35;
  background: rgba(255, 107, 53, 0.08);
  padding: 4px 12px;
  border-radius: 8px;
}

.question-score {
  font-size: 13px;
  font-weight: 600;
  color: #6b625c;
}

.question-content {
  font-size: 15px;
  color: #1f1a17;
  line-height: 1.7;
  margin-bottom: 20px;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 选择题选项 */
.question-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: #f9f7f4;
  border-radius: 12px;
  border: 2px solid transparent;
  transition: all 0.15s;
}

.option-item.selected {
  background: #fff3e0;
  border-color: #ff6b35;
}

.option-letter {
  width: 30px;
  height: 30px;
  background: #e8e5e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  color: #6b625c;
  margin-right: 12px;
  flex-shrink: 0;
}

.option-letter.selected {
  background: #ff6b35;
  color: #ffffff;
}

.option-text {
  font-size: 14px;
  color: #1f1a17;
  flex: 1;
  line-height: 1.5;
}

/* 判断题选项 */
.judge-options {
  display: flex;
  gap: 12px;
}

.judge-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 18px;
  background: #f9f7f4;
  border-radius: 12px;
  border: 2px solid transparent;
  transition: all 0.15s;
}

.judge-option.selected {
  background: #fff3e0;
  border-color: #ff6b35;
}

.judge-icon {
  font-size: 24px;
  margin-bottom: 6px;
}

.judge-text {
  font-size: 14px;
  font-weight: 600;
  color: #6b625c;
}

.judge-option.selected .judge-text {
  color: #ff6b35;
}

/* 问答题输入区 */
.text-answer-section {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.answer-textarea {
  width: 100%;
  padding: 14px;
  background: #f9f7f4;
  border-radius: 12px;
  font-size: 14px;
  line-height: 1.7;
  color: #1f1a17;
  border: 1px solid transparent;
  transition: all 0.15s;
  box-sizing: border-box;
}

.answer-textarea:focus {
  background: #ffffff;
  border-color: #ff6b35;
}

.voice-input-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5a 100%);
  border-radius: 12px;
  color: #ffffff;
  font-size: 14px;
  font-weight: 600;
}

.voice-icon {
  font-size: 16px;
  font-weight: 700;
}

/* 题号导航 */
.question-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 20px;
  padding: 16px;
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(60, 42, 28, 0.06);
}

.nav-dot {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f3f0;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 600;
  color: #6b625c;
  transition: all 0.15s;
}

.nav-dot.active {
  background: #ff6b35;
  color: #ffffff;
}

.nav-dot.answered {
  background: #e8f5e9;
  color: #4caf50;
}

.nav-dot.active.answered {
  background: #ff6b35;
  color: #ffffff;
}

/* 底部操作栏 */
.exam-footer {
  display: flex;
  gap: 12px;
  padding: 16px;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1px solid #eee6dc;
  z-index: 10;
}

.btn-secondary {
  flex: 1;
  height: 48px;
  background: #f5f3f0;
  color: #6b625c;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary[disabled] {
  opacity: 0.5;
}

.btn-primary {
  flex: 1;
  height: 48px;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 考试结果 */
.exam-result {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  padding: 16px;
}

.result-card {
  background: #ffffff;
  border-radius: 24px;
  padding: 32px 24px;
  text-align: center;
  width: 100%;
  max-width: min(340px, 90vw);
  box-shadow: 0 8px 24px rgba(60, 42, 28, 0.06);
}

.result-score-circle {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  margin: 0 auto 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.result-score-circle.pass {
  background: linear-gradient(135deg, #4caf50 0%, #66bb6a 100%);
}

.result-score-circle.fail {
  background: linear-gradient(135deg, #f44336 0%, #ef5350 100%);
}

.score-num {
  font-size: 48px;
  font-weight: 800;
  color: #ffffff;
}

.score-label {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.9);
}

.result-status {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 8px;
}

.result-status.passed {
  color: #4caf50;
}

.result-status.failed {
  color: #f44336;
}

.result-meta {
  font-size: 14px;
  color: #6b625c;
  margin-bottom: 20px;
}

.result-detail {
  display: flex;
  justify-content: center;
  gap: 24px;
  margin-bottom: 24px;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 12px;
  color: #9a958e;
  margin-bottom: 4px;
}

.detail-value {
  font-size: 22px;
  font-weight: 700;
}

.detail-value.correct {
  color: #4caf50;
}

.detail-value.wrong {
  color: #f44336;
}
