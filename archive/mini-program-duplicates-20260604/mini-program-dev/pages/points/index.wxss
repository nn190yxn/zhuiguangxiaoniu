.points-header {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5a 100%);
  border-radius: 20px;
  padding: 24px;
  margin: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.points-balance {
  display: flex;
  flex-direction: column;
}

.balance-label {
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  margin-bottom: 4px;
}

.balance-value {
  font-size: 40px;
  font-weight: 700;
  color: #ffffff;
}

.btn-checkin {
  background: rgba(255,255,255,0.2);
  border-radius: 20px;
  padding: 12px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: none;
}

.btn-checkin.checked {
  background: rgba(255,255,255,0.1);
}

.checkin-text {
  font-size: 14px;
  color: #ffffff;
  font-weight: 600;
}

.checkin-points {
  font-size: 12px;
  color: rgba(255,255,255,0.85);
  margin-top: 2px;
}

.stats-row {
  display: flex;
  gap: 12px;
  padding: 0 16px;
  margin-bottom: 16px;
}

.stat-item {
  flex: 1;
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  text-align: center;
}

.stat-value {
  font-size: 24px;
  font-weight: 700;
  color: #ff6b35;
}

.stat-label {
  font-size: 12px;
  color: #9a958e;
  margin-top: 4px;
}

.tabs {
  display: flex;
  padding: 0 16px;
  gap: 8px;
  margin-bottom: 16px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px;
  font-size: 14px;
  color: #6b625c;
  background: #ffffff;
  border-radius: 12px;
}

.tab-item.active {
  background: #ff6b35;
  color: #ffffff;
}

.tab-content {
  padding: 0 16px;
}

.rule-item, .record-item {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rule-name, .record-name {
  font-size: 14px;
  color: #1f1a17;
  margin-bottom: 4px;
}

.rule-desc, .record-time {
  font-size: 12px;
  color: #9a958e;
}

.rule-points, .record-points {
  font-size: 16px;
  font-weight: 600;
}

.rule-points.earn, .record-points.earn {
  color: #4caf50;
}

.rule-points.spend, .record-points.spend {
  color: #f44336;
}

.exchange-item {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  display: flex;
  gap: 12px;
}

.exchange-cover {
  width: 80px;
  height: 80px;
  border-radius: 12px;
  background-size: cover;
  background-position: center;
  background-color: #f0f0f0;
}

.exchange-info {
  flex: 1;
}

.exchange-title {
  font-size: 15px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 4px;
}

.exchange-desc {
  font-size: 12px;
  color: #9a958e;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.exchange-footer {
  display: flex;
  gap: 12px;
}

.exchange-points {
  font-size: 14px;
  color: #ff6b35;
  font-weight: 600;
}

.exchange-stock {
  font-size: 12px;
  color: #9a958e;
}

.btn-exchange {
  height: 36px;
  padding: 0 16px;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 18px;
  font-size: 13px;
  font-weight: 600;
  border: none;
  align-self: center;
}

.btn-exchange.disabled {
  background: #c5c0bb;
}

.empty, .loading {
  text-align: center;
  padding: 40px 0;
  color: #9a958e;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
}

.modal.show {
  display: flex;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  background: #ffffff;
  border-radius: 24px;
  padding: 24px;
  width: 90%;
  max-width: 360px;
  z-index: 1;
}

.modal-header {
  text-align: center;
  margin-bottom: 16px;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #1f1a17;
}

.exchange-preview {
  background: #fff3e0;
  border-radius: 16px;
  padding: 16px;
  text-align: center;
  margin-bottom: 16px;
}

.preview-title {
  font-size: 15px;
  color: #1f1a17;
  margin-bottom: 4px;
}

.preview-points {
  font-size: 18px;
  color: #ff6b35;
  font-weight: 600;
}

.exchange-form input,
.exchange-form textarea {
  width: 100%;
  border: 1px solid rgba(0,0,0,0.1);
  border-radius: 12px;
  padding: 12px;
  font-size: 14px;
  margin-bottom: 12px;
  box-sizing: border-box;
}

.exchange-form textarea {
  height: 80px;
  resize: none;
}

.form-actions {
  display: flex;
  gap: 12px;
  margin-top: 8px;
}

.btn-secondary {
  flex: 1;
  height: 44px;
  background: rgba(0,0,0,0.05);
  color: #6b625c;
  border-radius: 22px;
  font-size: 14px;
  font-weight: 600;
  border: none;
}

.btn-primary {
  flex: 1;
  height: 44px;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 22px;
  font-size: 14px;
  font-weight: 600;
  border: none;
}