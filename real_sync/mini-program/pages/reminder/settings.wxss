.hero-card,
.rule-card,
.status-card,
.action-card,
.list-card {
  background: #ffffff;
  border-radius: 18px;
  padding: 18px;
  margin-bottom: 14px;
}

.hero-card {
  background: linear-gradient(135deg, #1f1a17 0%, #5c3426 62%, #ff6b35 120%);
}

.hero-title {
  font-size: 22px;
  font-weight: 700;
  color: #ffffff;
}

.hero-desc {
  margin-top: 10px;
  font-size: 13px;
  line-height: 1.7;
  color: rgba(255,255,255,0.84);
}

.section-title {
  font-size: 16px;
  font-weight: 700;
  color: #1f1a17;
  margin-bottom: 12px;
}

.rule-item,
.status-card,
.subscription-desc,
.subscription-meta,
.empty,
.action-desc {
  font-size: 13px;
  line-height: 1.7;
  color: #6b625c;
}

.rule-item {
  padding: 10px 12px;
  background: #fbf8f4;
  border-radius: 12px;
  margin-bottom: 10px;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-copy {
  flex: 1;
  padding-right: 16px;
}

.action-title,
.subscription-title {
  font-size: 15px;
  font-weight: 700;
  color: #1f1a17;
}

.action-btn {
  margin: 0;
  background: #ff6b35;
  color: #ffffff;
  font-size: 14px;
  border-radius: 999px;
  padding: 0 20px;
  line-height: 40px;
}

.action-btn::after {
  border: none;
}

.subscription-item {
  padding: 14px 0;
  border-bottom: 1px solid rgba(31,26,23,0.08);
}

.subscription-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.subscription-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.subscription-status {
  font-size: 12px;
  font-weight: 700;
  border-radius: 999px;
  padding: 4px 10px;
}

.status-accept {
  background: rgba(47, 158, 68, 0.12);
  color: #2f9e44;
}

.status-reject,
.status-ban {
  background: rgba(211, 84, 84, 0.12);
  color: #d35454;
}

.status-unknown {
  background: #fbf8f4;
  color: #9a958e;
}

.subscription-meta {
  margin-top: 6px;
}

.empty {
  padding: 12px 0 0;
}
