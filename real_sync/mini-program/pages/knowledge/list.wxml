<wxs src="../../utils/wxml.wxs" module="wxs" />

<view class="container">
  <view class="search-bar">
    <input
      type="text"
      value="{{searchValue}}"
      placeholder="搜索知识标题、内容、标签"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
      confirm-type="search"
    />
    <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">清除</view>
  </view>

  <scroll-view scroll-x class="type-tabs" enable-flex>
    <view
      class="type-tab {{wxs.classIfEq(currentType, item.type, 'active')}}"
      wx:for="{{typeTabs}}"
      wx:key="type"
      bindtap="selectType"
      data-type="{{item.type}}"
    >
      <text>{{item.name}}</text>
      <text class="type-count">{{item.count}}</text>
    </view>
  </scroll-view>

  <view class="filter-panel" wx:if="{{wxs.len(visibleCategories)}}">
    <view class="filter-title-row">
      <view class="filter-title">知识分类</view>
      <view class="filter-reset" bindtap="resetFilters">重置</view>
    </view>
    <scroll-view scroll-x class="category-scroll" enable-flex>
      <view
        class="category-chip {{wxs.classIfEq(currentCategoryId, 0, 'active')}}"
        bindtap="selectCategory"
        data-id="0"
      >
        <text class="category-icon">全</text>
        <text>全部分类</text>
      </view>
      <view
        class="category-chip {{wxs.classIfEq(currentCategoryId, item.id, 'active')}}"
        wx:for="{{visibleCategories}}"
        wx:key="id"
        bindtap="selectCategory"
        data-id="{{item.id}}"
      >
        <text class="category-icon">{{item.display_icon}}</text>
        <text>{{item.name}}</text>
        <text class="category-count">{{item.item_count}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="expanded-filters" wx:if="{{wxs.eq(currentType, 'action')}}">
    <view class="filter-section">
      <view class="filter-label">科目</view>
      <scroll-view scroll-x class="filter-scroll" enable-flex>
        <view class="filter-tag {{wxs.classIfEq(currentSubject, '', 'active')}}" bindtap="selectSubject" data-value="">全部</view>
        <view class="filter-tag {{wxs.classIfEq(currentSubject, 'fitness', 'active')}}" bindtap="selectSubject" data-value="fitness">体能</view>
        <view class="filter-tag {{wxs.classIfEq(currentSubject, 'sensory', 'active')}}" bindtap="selectSubject" data-value="sensory">感统</view>
        <view class="filter-tag {{wxs.classIfEq(currentSubject, 'skill', 'active')}}" bindtap="selectSubject" data-value="skill">技能</view>
      </scroll-view>
    </view>

    <view class="filter-section">
      <view class="filter-label">年龄段</view>
      <scroll-view scroll-x class="filter-scroll" enable-flex>
        <view class="filter-tag {{wxs.classIfEq(currentAgeGroup, '', 'active')}}" bindtap="selectAgeGroup" data-value="">全部</view>
        <view class="filter-tag {{wxs.classIfEq(currentAgeGroup, '3-6', 'active')}}" bindtap="selectAgeGroup" data-value="3-6">3-6岁</view>
        <view class="filter-tag {{wxs.classIfEq(currentAgeGroup, '7-12', 'active')}}" bindtap="selectAgeGroup" data-value="7-12">7-12岁</view>
        <view class="filter-tag {{wxs.classIfEq(currentAgeGroup, '13-18', 'active')}}" bindtap="selectAgeGroup" data-value="13-18">13-18岁</view>
        <view class="filter-tag {{wxs.classIfEq(currentAgeGroup, '成人', 'active')}}" bindtap="selectAgeGroup" data-value="成人">成人</view>
      </scroll-view>
    </view>

    <view class="filter-section">
      <view class="filter-label">训练类别</view>
      <scroll-view scroll-x class="filter-scroll" enable-flex>
        <view class="filter-tag {{wxs.classIfEq(currentTrainingType, '', 'active')}}" bindtap="selectTrainingType" data-value="">全部</view>
        <view class="filter-tag {{wxs.classIfEq(currentTrainingType, 'strength', 'active')}}" bindtap="selectTrainingType" data-value="strength">力量</view>
        <view class="filter-tag {{wxs.classIfEq(currentTrainingType, 'cardio', 'active')}}" bindtap="selectTrainingType" data-value="cardio">心肺</view>
        <view class="filter-tag {{wxs.classIfEq(currentTrainingType, 'flexibility', 'active')}}" bindtap="selectTrainingType" data-value="flexibility">柔韧</view>
        <view class="filter-tag {{wxs.classIfEq(currentTrainingType, 'balance', 'active')}}" bindtap="selectTrainingType" data-value="balance">平衡</view>
        <view class="filter-tag {{wxs.classIfEq(currentTrainingType, 'coordination', 'active')}}" bindtap="selectTrainingType" data-value="coordination">协调</view>
      </scroll-view>
    </view>
  </view>

  <view class="list-summary" wx:if="{{wxs.or(searchKeyword, total)}}">
    <text wx:if="{{searchKeyword}}">搜索“{{searchKeyword}}” · </text>
    <text>共 {{total}} 条内容</text>
  </view>

  <view class="knowledge-list">
    <view
      class="knowledge-card"
      wx:for="{{list}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="knowledge-cover" style="background:{{item.cover_bg}}">
        <text class="cover-icon">{{item.cover_icon}}</text>
      </view>
      <view class="knowledge-info">
        <view class="knowledge-title">{{item.title}}</view>
        <view class="knowledge-summary">{{item.summary}}</view>
        <view class="knowledge-tags">
          <text class="tag primary">{{item.category_name}}</text>
          <text class="tag">{{item.type_name}}</text>
          <text class="tag" wx:if="{{item.subject_name}}">{{item.subject_name}}</text>
          <text class="tag" wx:if="{{item.age_group}}">{{item.age_group}}岁</text>
          <text class="tag" wx:if="{{item.training_name}}">{{item.training_name}}</text>
          <text class="tag" wx:for="{{item.display_tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
      </view>
      <view class="knowledge-status">
        <text wx:if="{{item.is_completed}}" class="status-text completed">已学</text>
      </view>
    </view>

    <view class="empty" wx:if="{{wxs.and(wxs.eq(wxs.len(list), 0), wxs.not(loading))}}">
      <text>暂无匹配内容</text>
      <view class="empty-action" bindtap="resetFilters">查看全部知识</view>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
