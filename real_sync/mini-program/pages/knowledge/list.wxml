<view class="container">
  <view class="search-bar">
    <input type="text" placeholder="搜索动作、话术、知识..." bindinput="onSearch" bindconfirm="onSearch" />
  </view>

  <scroll-view scroll-x class="category-tabs" enable-flex>
    <view class="tab-item {{currentType === '' ? 'active' : ''}}" bindtap="selectType" data-type="">全部</view>
    <view class="tab-item {{currentType === 'action' ? 'active' : ''}}" bindtap="selectType" data-type="action">动作库</view>
    <view class="tab-item {{currentType === 'script' ? 'active' : ''}}" bindtap="selectType" data-type="script">话术库</view>
    <view class="tab-item {{currentType === 'knowledge_card' ? 'active' : ''}}" bindtap="selectType" data-type="knowledge_card">知识卡</view>
  </scroll-view>

  <view class="expanded-filters" wx:if="{{currentType === 'action'}}">
    <view class="filter-section">
      <view class="filter-label">科目</view>
      <scroll-view scroll-x class="filter-scroll" enable-flex>
        <view class="filter-tag {{currentSubject === '' ? 'active' : ''}}" bindtap="selectSubject" data-value="">全部</view>
        <view class="filter-tag {{currentSubject === 'fitness' ? 'active' : ''}}" bindtap="selectSubject" data-value="fitness">体能</view>
        <view class="filter-tag {{currentSubject === 'sensory' ? 'active' : ''}}" bindtap="selectSubject" data-value="sensory">感统</view>
        <view class="filter-tag {{currentSubject === 'skill' ? 'active' : ''}}" bindtap="selectSubject" data-value="skill">技能</view>
      </scroll-view>
    </view>

    <view class="filter-section">
      <view class="filter-label">年龄段</view>
      <scroll-view scroll-x class="filter-scroll" enable-flex>
        <view class="filter-tag {{currentAgeGroup === '' ? 'active' : ''}}" bindtap="selectAgeGroup" data-value="">全部</view>
        <view class="filter-tag {{currentAgeGroup === '3-6' ? 'active' : ''}}" bindtap="selectAgeGroup" data-value="3-6">3-6岁</view>
        <view class="filter-tag {{currentAgeGroup === '7-12' ? 'active' : ''}}" bindtap="selectAgeGroup" data-value="7-12">7-12岁</view>
        <view class="filter-tag {{currentAgeGroup === '13-18' ? 'active' : ''}}" bindtap="selectAgeGroup" data-value="13-18">13-18岁</view>
        <view class="filter-tag {{currentAgeGroup === '成人' ? 'active' : ''}}" bindtap="selectAgeGroup" data-value="成人">成人</view>
      </scroll-view>
    </view>

    <view class="filter-section">
      <view class="filter-label">训练类别</view>
      <scroll-view scroll-x class="filter-scroll" enable-flex>
        <view class="filter-tag {{currentTrainingType === '' ? 'active' : ''}}" bindtap="selectTrainingType" data-value="">全部</view>
        <view class="filter-tag {{currentTrainingType === 'strength' ? 'active' : ''}}" bindtap="selectTrainingType" data-value="strength">力量</view>
        <view class="filter-tag {{currentTrainingType === 'cardio' ? 'active' : ''}}" bindtap="selectTrainingType" data-value="cardio">心肺</view>
        <view class="filter-tag {{currentTrainingType === 'flexibility' ? 'active' : ''}}" bindtap="selectTrainingType" data-value="flexibility">柔韧</view>
        <view class="filter-tag {{currentTrainingType === 'balance' ? 'active' : ''}}" bindtap="selectTrainingType" data-value="balance">平衡</view>
        <view class="filter-tag {{currentTrainingType === 'coordination' ? 'active' : ''}}" bindtap="selectTrainingType" data-value="coordination">协调</view>
      </scroll-view>
    </view>
  </view>

  <view class="knowledge-list">
    <view class="knowledge-card" wx:for="{{list}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="card-badge {{item.category_type || 'default'}}">{{item.category_type_name || '知识'}}</view>
      <view class="card-title">{{item.title}}</view>
      <view class="card-props" wx:if="{{item.subject_name || item.age_group || item.difficulty}}">
        <text class="prop-item" wx:if="{{item.subject_name}}">{{item.subject_name}}</text>
        <text class="prop-item" wx:if="{{item.age_group}}">{{item.age_group}}岁</text>
        <text class="prop-item level" wx:if="{{item.difficulty}}">{{item.difficulty}}级</text>
      </view>
      <view class="card-summary">{{item.summary || '暂无简介'}}</view>
      <view class="card-footer">
        <view class="card-tags">
          <text class="tag" wx:if="{{item.is_public}}">公共</text>
          <text class="tag" wx:if="{{item.training_name}}">{{item.training_name}}</text>
        </view>
        <view class="card-status">
          <text wx:if="{{item.is_completed}}" class="done">已完成</text>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{list.length === 0 && !loading}}">
      <text>{{emptyText}}</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>