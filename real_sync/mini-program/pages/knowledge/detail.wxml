<view class="container" style="padding-bottom:100px;">
  <view class="detail-header" wx:if="{{item.media_type === 'image' || item.media_type === 'video'}}">
    <image mode="aspectFill" src="{{item.media_url}}" />
    <view class="play-icon" wx:if="{{item.media_type === 'video'}}">▶</view>
  </view>
  <view class="detail-header-placeholder" wx:else>
    <text class="placeholder-icon">{{item.placeholder_icon || '知识'}}</text>
  </view>

  <view class="detail-content">
    <view class="detail-title">{{item.title}}</view>

    <view class="detail-meta">
      <text class="meta-badge type">{{categoryTypeName}}</text>
      <text wx:if="{{item.difficulty}}" class="meta-text">{{item.difficulty}}级</text>
      <text wx:if="{{item.view_count}}" class="meta-text">{{item.view_count}} 浏览</text>
    </view>

    <view class="detail-props" wx:if="{{tags.length > 0}}">
      <text class="prop-tag {{item.type}}" wx:for="{{tags}}" wx:key="index">{{item.name}}</text>
    </view>

    <view class="detail-body" wx:if="{{contentMode === 'sections'}}">
      <view class="content-section" wx:for="{{contentSections}}" wx:key="index">
        <view class="content-section-title">{{item.title}}</view>
        <view class="content-section-body">
          <view class="content-paragraph" wx:for="{{item.paragraphs}}" wx:key="index" wx:for-item="paragraph">{{paragraph}}</view>
        </view>
      </view>
    </view>

    <view class="detail-body" wx:elif="{{contentMode === 'html'}}">
      <rich-text nodes="{{contentNodes}}"></rich-text>
    </view>

    <view class="section" wx:if="{{drills.length > 0}}">
      <view class="section-title">关联演练</view>
      <view class="drill-card" wx:for="{{drills}}" wx:key="id" wx:for-item="drill">
        <view class="drill-card-header">
          <view class="drill-card-title">{{drill.title}}</view>
          <view class="drill-card-badge {{drill.task_status}}">{{drill.status_text}}</view>
        </view>
        <view class="drill-card-desc">{{drill.description || '完成知识学习后开始演练'}}</view>
        <view class="drill-card-footer">
          <text class="drill-card-progress">学习进度: {{drill.task_progress || 0}}%</text>
          <button class="drill-card-btn" data-id="{{drill.id}}" bindtap="goToDrill">{{drill.button_text}}</button>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{scripts.length > 0}}">
      <view class="section-title">相关话术</view>
      <view class="script-card" wx:for="{{scripts}}" wx:key="id" wx:for-item="script">
        <view class="script-scene">{{script.scene || '场景'}}</view>
        <view class="script-content">{{script.content}}</view>
        <button class="script-audio" wx:if="{{script.audio_url}}" data-url="{{script.audio_url}}" bindtap="playAudio">播放示范</button>
      </view>
    </view>

    <view class="section" wx:if="{{related.length > 0}}">
      <view class="section-title">相关知识</view>
      <view class="related-item" wx:for="{{related}}" wx:key="id" bindtap="goToRelated" data-id="{{item.id}}">
        <view class="related-cover">
          <text>{{item.cover_icon}}</text>
        </view>
        <view class="related-info">
          <view class="related-name">{{item.title}}</view>
          <view class="related-type">{{item.category_type_name}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="detail-footer" wx:if="{{!loading && item.id}}">
    <button class="btn-secondary {{isCompleted ? 'completed' : ''}}" bindtap="markComplete">
      {{isCompleted ? '已完成' : '标记完成'}}
    </button>
  </view>
</view>
