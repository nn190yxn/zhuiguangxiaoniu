.container {
  min-height: 100vh;
  background: #f5f3f0;
  padding-bottom: 24px;
}

.search-bar {
  margin: 16px;
  background: #ffffff;
  border-radius: 12px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 4px 14px rgba(31, 26, 23, 0.04);
}

.search-bar input {
  flex: 1;
  min-width: 0;
  font-size: 14px;
  color: #1f1a17;
}

.search-clear {
  font-size: 12px;
  color: #ff6b35;
  flex-shrink: 0;
}

.type-tabs {
  padding: 0 16px;
  white-space: nowrap;
  margin-bottom: 12px;
}

.type-tab {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  font-size: 13px;
  color: #6b625c;
  background: #ffffff;
  border-radius: 18px;
  margin-right: 8px;
  border: 1px solid #eee7e1;
}

.type-tab.active {
  background: #ff6b35;
  color: #ffffff;
  border-color: #ff6b35;
}

.type-count {
  font-size: 11px;
  opacity: 0.8;
}

.filter-panel,
.expanded-filters {
  background: #ffffff;
  padding: 12px 16px;
  margin: 0 16px 12px;
  border-radius: 12px;
  box-shadow: 0 4px 14px rgba(31, 26, 23, 0.04);
}

.filter-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.filter-title {
  font-size: 14px;
  font-weight: 700;
  color: #1f1a17;
}

.filter-reset {
  font-size: 12px;
  color: #9a958e;
}

.category-scroll,
.filter-scroll {
  white-space: nowrap;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  max-width: 180px;
  padding: 7px 10px;
  margin-right: 8px;
  border-radius: 10px;
  background: #f8f6f3;
  color: #5a514b;
  font-size: 12px;
  border: 1px solid #eee7e1;
}

.category-chip.active {
  color: #ff6b35;
  background: #fff3ec;
  border-color: #ffd7c5;
}

.category-icon {
  width: 20px;
  height: 20px;
  border-radius: 6px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
}

.category-count {
  color: #9a958e;
  font-size: 11px;
  flex-shrink: 0;
}

.filter-section {
  margin-bottom: 12px;
}

.filter-section:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 12px;
  color: #9a958e;
  margin-bottom: 8px;
}

.filter-tag {
  display: inline-block;
  padding: 6px 12px;
  font-size: 12px;
  color: #6b625c;
  background: #f5f3f0;
  border-radius: 14px;
  margin-right: 8px;
}

.filter-tag.active {
  background: #ff6b35;
  color: #ffffff;
}

.list-summary {
  padding: 0 16px 10px;
  color: #9a958e;
  font-size: 12px;
}

.knowledge-list {
  padding: 0 16px;
}

.knowledge-card {
  background: #ffffff;
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 10px;
  display: flex;
  gap: 12px;
  box-shadow: 0 4px 14px rgba(31, 26, 23, 0.04);
}

.knowledge-cover {
  width: 56px;
  height: 56px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cover-icon {
  font-size: 22px;
  font-weight: 700;
  color: #1f1a17;
}

.knowledge-info {
  flex: 1;
  min-width: 0;
}

.knowledge-title {
  font-size: 15px;
  font-weight: 700;
  color: #1f1a17;
  line-height: 1.4;
  margin-bottom: 5px;
}

.knowledge-summary {
  font-size: 12px;
  color: #7a716b;
  line-height: 1.55;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.knowledge-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}

.tag {
  padding: 2px 7px;
  background: #f5f3f0;
  border-radius: 7px;
  font-size: 10px;
  line-height: 1.6;
  color: #6b625c;
}

.tag.primary {
  background: #fff3ec;
  color: #ff6b35;
}

.knowledge-status {
  display: flex;
  align-items: flex-start;
  flex-shrink: 0;
}

.status-text {
  font-size: 11px;
  color: #9a958e;
}

.status-text.completed {
  color: #2e8b57;
  background: #e8f5e9;
  padding: 2px 6px;
  border-radius: 7px;
}

.empty,
.loading {
  text-align: center;
  padding: 54px 0;
  color: #9a958e;
  font-size: 14px;
}

.empty-action {
  display: inline-block;
  margin-top: 12px;
  padding: 8px 14px;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 16px;
  font-size: 12px;
}
