.search-bar {
  margin: 16px;
  background: #ffffff;
  border-radius: 24px;
  padding: 10px 16px;
  display: flex;
  align-items: center;
}

.search-bar input {
  flex: 1;
  font-size: 14px;
  border: none;
  outline: none;
}

.category-tabs {
  padding: 0 16px;
  white-space: nowrap;
  margin-bottom: 16px;
}

.tab-item {
  display: inline-block;
  padding: 8px 16px;
  font-size: 13px;
  color: #6b625c;
  background: #ffffff;
  border-radius: 20px;
  margin-right: 8px;
}

.tab-item.active {
  background: #ff6b35;
  color: #ffffff;
}

.knowledge-list {
  padding: 0 16px;
}

.knowledge-card {
  position: relative;
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
}

.card-badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 600;
  margin-bottom: 10px;
}

.card-badge.action,
.card-badge.default {
  background: #e3f2fd;
  color: #1976d2;
}

.card-badge.script {
  background: #f3e5f5;
  color: #7b1fa2;
}

.card-badge.knowledge_card {
  background: #e8f5e9;
  color: #388e3c;
}

.card-title {
  font-size: 16px;
  font-weight: 700;
  color: #1f1a17;
  line-height: 1.4;
  margin-bottom: 8px;
}

.card-props {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.prop-item {
  padding: 2px 10px;
  border-radius: 6px;
  font-size: 11px;
  background: #f5f3f0;
  color: #6b625c;
}

.prop-item.level {
  background: #fff3e0;
  color: #e65100;
}

.card-summary {
  font-size: 13px;
  color: #5f5751;
  line-height: 1.6;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-tags {
  display: flex;
  gap: 6px;
}

.tag {
  padding: 2px 8px;
  background: #f5f3f0;
  border-radius: 6px;
  font-size: 11px;
  color: #6b625c;
}

.card-status {
  flex-shrink: 0;
}

.done {
  font-size: 12px;
  color: #4caf50;
  font-weight: 600;
}

.expanded-filters {
  background: #ffffff;
  padding: 12px 16px;
  margin: 0 16px 12px;
  border-radius: 12px;
}

.filter-section {
  margin-bottom: 10px;
}

.filter-section:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 12px;
  color: #9a958e;
  margin-bottom: 6px;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-tag {
  display: inline-block;
  padding: 5px 12px;
  font-size: 12px;
  color: #6b625c;
  background: #f5f3f0;
  border-radius: 14px;
  margin-right: 8px;
}

.filter-tag.active {
  background: #ff6b35;
  color: #ffffff;
}

.empty, .loading {
  text-align: center;
  padding: 60px 0;
  color: #9a958e;
}