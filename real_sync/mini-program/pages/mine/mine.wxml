<view class="container">
  <view class="user-card">
    <view class="user-info">
      <image wx:if="{{userInfo && userInfo.avatar}}" class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"/>
      <view wx:else class="avatar avatar-placeholder">{{(userInfo.display_name || userInfo.username || '用').slice(0, 1)}}</view>
      <view class="user-detail">
        <view class="username">{{userInfo.display_name || userInfo.username || '用户'}}</view>
        <view class="dept" wx:if="{{userInfo.department}}">{{userInfo.department}}</view>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToWorkload">
      <view class="menu-left">
        <text class="menu-icon">工作</text>
        <text class="menu-text">工作量日报</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToNotifications">
      <view class="menu-left">
        <text class="menu-icon">通知</text>
        <text class="menu-text">通知与待办</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToReminderSettings">
      <view class="menu-left">
        <text class="menu-icon">提醒</text>
        <text class="menu-text">提醒设置</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <view class="menu-left">
        <text class="menu-icon">缓存</text>
        <text class="menu-text">清除缓存</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="checkUpdate">
      <view class="menu-left">
        <text class="menu-icon">版本</text>
        <text class="menu-text">版本信息</text>
      </view>
      <view class="menu-right">
        <text class="version">v1.0.0</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="logout-btn" bindtap="logout">
    退出登录
  </view>
</view>
