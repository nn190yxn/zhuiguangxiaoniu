<wxs src="../../utils/wxml.wxs" module="wxs" />

<view class="container">
  <view class="user-card">
    <view class="user-info">
      <view class="avatar">{{avatarText}}</view>
      <view class="user-detail">
        <view class="username">{{wxs.fallback3(userInfo.display_name, userInfo.username, '用户')}}</view>
        <view class="dept" wx:if="{{userInfo.department}}">{{userInfo.department}}</view>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToWorkload">
      <view class="menu-left">
        <text class="menu-icon">📊</text>
        <text class="menu-text">工作量日报</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSubscription">
      <view class="menu-left">
        <text class="menu-icon">🔔</text>
        <text class="menu-text">消息订阅设置</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToReadHistory">
      <view class="menu-left">
        <text class="menu-icon">📖</text>
        <text class="menu-text">阅读历史</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <view class="menu-left">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除缓存</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="checkUpdate">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">版本信息</text>
      </view>
      <view class="menu-right">
        <text class="version">v1.0.0</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="logout-btn" bindtap="logout">
    退出登录
  </view>
</view>
