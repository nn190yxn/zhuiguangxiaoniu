<view class="container">
  <!-- Search Section -->
  <view class="search-section">
    <view class="search-wrapper">
      <input
        class="search-input"
        type="search"
        placeholder="输入关键词搜索制度..."
        value="{{keyword}}"
        bindinput="onInputChange"
        bindconfirm="doSearch"
      />
      <view class="search-btn" bindtap="doSearch">搜</view>
    </view>
  </view>

  <!-- Category Filter -->
  <view class="filter-section">
    <view class="filter-label">角色分类</view>
    <scroll-view class="filter-scroll" scroll-x enable-flex>
      <view
        class="filter-tag {{currentCategory === '' ? 'active' : ''}}"
        bindtap="switchCategory"
        data-value=""
      >全部</view>
      <view
        class="filter-tag {{currentCategory === '通用' ? 'active' : ''}}"
        bindtap="switchCategory"
        data-value="通用"
      >通用</view>
      <view
        class="filter-tag {{currentCategory === '店长' ? 'active' : ''}}"
        bindtap="switchCategory"
        data-value="店长"
      >店长</view>
      <view
        class="filter-tag {{currentCategory === '教练' ? 'active' : ''}}"
        bindtap="switchCategory"
        data-value="教练"
      >教练</view>
      <view
        class="filter-tag {{currentCategory === '顾问' ? 'active' : ''}}"
        bindtap="switchCategory"
        data-value="顾问"
      >顾问</view>
    </scroll-view>
  </view>

  <!-- Workflow Filter -->
  <view class="filter-section">
    <view class="filter-label">工作流程</view>
    <scroll-view class="filter-scroll" scroll-x enable-flex>
      <view
        class="filter-tag {{currentWorkflow === '' ? 'active' : ''}}"
        bindtap="switchWorkflow"
        data-value=""
      >全部</view>
      <view
        class="filter-tag {{currentWorkflow === '入职' ? 'active' : ''}}"
        bindtap="switchWorkflow"
        data-value="入职"
      >入职流程</view>
      <view
        class="filter-tag {{currentWorkflow === '离职' ? 'active' : ''}}"
        bindtap="switchWorkflow"
        data-value="离职"
      >离职流程</view>
      <view
        class="filter-tag {{currentWorkflow === '考勤' ? 'active' : ''}}"
        bindtap="switchWorkflow"
        data-value="考勤"
      >考勤制度</view>
      <view
        class="filter-tag {{currentWorkflow === '绩效' ? 'active' : ''}}"
        bindtap="switchWorkflow"
        data-value="绩效"
      >绩效考核</view>
      <view
        class="filter-tag {{currentWorkflow === '培训' ? 'active' : ''}}"
        bindtap="switchWorkflow"
        data-value="培训"
      >培训管理</view>
    </scroll-view>
  </view>

  <!-- Quick Links -->
  <view class="quick-links" wx:if="{{!hasSearched}}">
    <view class="quick-links-title">常用制度</view>
    <view class="quick-links-grid">
      <view class="quick-link" bindtap="quickSearch" data-keyword="员工手册">
        <view class="quick-link-icon">册</view>
        <view class="quick-link-text">员工手册</view>
      </view>
      <view class="quick-link" bindtap="quickSearch" data-keyword="考勤制度">
        <view class="quick-link-icon">勤</view>
        <view class="quick-link-text">考勤制度</view>
      </view>
      <view class="quick-link" bindtap="quickSearch" data-keyword="绩效考核">
        <view class="quick-link-icon">绩</view>
        <view class="quick-link-text">绩效考核</view>
      </view>
      <view class="quick-link" bindtap="quickSearch" data-keyword="培训管理">
        <view class="quick-link-icon">培</view>
        <view class="quick-link-text">培训管理</view>
      </view>
    </view>
  </view>

  <!-- Results -->
  <view class="results-section" wx:if="{{hasSearched}}">
    <view class="result-count">
      找到 <text class="highlight">{{total}}</text> 个匹配的制度
    </view>
  </view>

  <!-- Policy List -->
  <view class="policy-list">
    <view
      class="policy-card"
      wx:for="{{policies}}"
      wx:key="id"
      bindtap="viewPolicy"
      data-id="{{item.id}}"
    >
      <view class="policy-header">
        <view class="policy-title">{{item.title}}</view>
        <view class="policy-badge required" wx:if="{{item.is_need_confirm}}">需确认</view>
      </view>
      <view class="policy-meta">
        <text>{{item.category}}</text>
        <text wx:if="{{item.workflow}}">{{item.workflow}}</text>
        <text>v{{item.version}}</text>
      </view>
      <view class="policy-footer">
        <text class="policy-time">更新: {{item.updated_at}}</text>
        <view class="policy-btn">
          {{item.is_need_confirm ? '阅读并确认' : '查看详情'}}
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{hasSearched && policies.length === 0 && !loading}}">
      <text>搜</text>
      <text class="empty-text">{{emptyText}}</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>搜索中...</text>
    </view>
  </view>
</view>
