.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 16px 16px 96px;
  background: #f5f3f0;
}

.hero {
  margin-bottom: 14px;
  padding: 20px;
  border-radius: 22px;
  background: linear-gradient(135deg, #ff6b35, #ff9a5f);
  box-shadow: 0 8px 20px rgba(255, 107, 53, 0.2);
  color: #fff;
}

.hero-title {
  margin-bottom: 6px;
  font-size: 22px;
  font-weight: 800;
}

.hero-sub {
  font-size: 13px;
  line-height: 1.6;
  opacity: 0.92;
}

.user-pill {
  display: inline-flex;
  margin-top: 10px;
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.2);
  font-size: 12px;
  font-weight: 700;
}

.card {
  margin-bottom: 14px;
  padding: 16px;
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 18px;
  background: #fff;
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.04);
}

.draft-tip {
  margin-bottom: 12px;
  padding: 10px 12px;
  border-radius: 12px;
  background: #fff8e8;
  color: #8a5a00;
  font-size: 12px;
  line-height: 1.7;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.field {
  margin-bottom: 12px;
}

.label {
  display: block;
  margin-bottom: 6px;
  color: #6b625c;
  font-size: 12px;
  font-weight: 700;
}

.picker-value,
.input,
.textarea {
  box-sizing: border-box;
  padding: 11px 12px;
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 12px;
  background: #fafafa;
  font-size: 15px;
}

.input {
  width: 100%;
}

.textarea {
  width: 100%;
  height: 84px;
}

.status {
  color: #6b625c;
  font-size: 13px;
  line-height: 1.6;
}

.status.ok {
  color: #087443;
}

.status.err {
  color: #b42318;
}

.metric {
  padding: 12px 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.metric:last-child {
  border-bottom: none;
}

.metric-main {
  display: grid;
  grid-template-columns: 1fr 112px;
  gap: 12px;
  align-items: center;
}

.metric-name {
  color: #1f1a17;
  font-size: 14px;
  font-weight: 750;
}

.metric-meta {
  margin-top: 3px;
  color: #6b625c;
  font-size: 11px;
}

.metric-input {
  padding: 10px;
  border: 1px solid rgba(255, 107, 53, 0.2);
  border-radius: 12px;
  background: #fff7ed;
  color: #ff6b35;
  text-align: center;
  font-weight: 800;
}

.evidence-box {
  margin-top: 10px;
  padding: 10px 12px;
  border: 1px dashed rgba(255, 107, 53, 0.35);
  border-radius: 14px;
  background: #fff7f2;
}

.evidence-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}

.evidence-title {
  color: #ff6b35;
  font-size: 12px;
  font-weight: 800;
}

.evidence-tip,
.evidence-empty {
  margin-top: 8px;
  color: #6b625c;
  font-size: 12px;
  line-height: 1.6;
}

.evidence-btn {
  margin-top: 10px;
  border-radius: 12px;
  background: #ff6b35;
  color: #fff;
  font-size: 14px;
  font-weight: 700;
}

.evidence-list {
  display: grid;
  gap: 10px;
  margin-top: 10px;
}

.evidence-item {
  padding: 10px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.95);
}

.evidence-image {
  width: 100%;
  height: 156px;
  border-radius: 10px;
  background: #f1ede7;
}

.evidence-name {
  margin-top: 8px;
  color: #1f1a17;
  font-size: 12px;
  font-weight: 600;
}

.evidence-card-actions {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

.evidence-mini-btn {
  flex: 1;
  min-height: 32px;
  margin: 0;
  border-radius: 10px;
  background: #fff;
  color: #6b625c;
  font-size: 12px;
}

.evidence-mini-btn.danger {
  color: #b42318;
}

.empty {
  color: #6b625c;
  font-size: 13px;
  text-align: center;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.btn {
  border-radius: 14px;
  font-size: 15px;
  font-weight: 800;
}

.btn.secondary {
  background: #fff;
  color: #6b625c;
}

.btn.primary {
  background: #ff6b35;
  color: #fff;
}

.privacy-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: rgba(15, 23, 42, 0.48);
  z-index: 99;
}

.privacy-dialog {
  width: 100%;
  max-width: 640rpx;
  padding: 20px;
  border-radius: 18px;
  background: #fff;
  box-sizing: border-box;
}

.privacy-title {
  color: #1f1a17;
  font-size: 18px;
  font-weight: 800;
}

.privacy-desc {
  margin-top: 10px;
  color: #6b625c;
  font-size: 14px;
  line-height: 1.7;
}

.privacy-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 16px;
}

.privacy-btn {
  margin-top: 10px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 700;
}

.privacy-btn.secondary {
  margin-top: 0;
  background: #fff7ed;
  color: #ff6b35;
}

.privacy-btn.plain {
  margin-top: 0;
  background: #fff;
  color: #6b625c;
}

.privacy-btn.primary {
  background: #ff6b35;
  color: #fff;
}
