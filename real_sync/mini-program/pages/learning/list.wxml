<wxs src="../../utils/wxml.wxs" module="wxs" />

<view class="container">
  <!-- Header Card with Points -->
  <view class="header-card">
    <view class="points-info">
      <text class="points-label">我的积分</text>
      <text class="points-value">{{totalPoints}}</text>
    </view>
    <view class="checkin-btn {{wxs.classIf(todayChecked, 'checked')}}" bindtap="doCheckin">
      <text class="checkin-text">{{wxs.choose(todayChecked, '已签到', '签到')}}</text>
      <text class="checkin-points" wx:if="{{!todayChecked}}">+5</text>
    </view>
  </view>

  <!-- Quick Entry Section -->
  <view class="quick-entry">
    <view class="quick-entry-item" bindtap="goToKnowledge">
      <view class="quick-entry-icon knowledge">🧠</view>
      <view class="quick-entry-text">
        <view class="quick-entry-title">通用知识</view>
        <view class="quick-entry-desc">体测/感统/工作标准</view>
      </view>
    </view>
    <view class="quick-entry-item" bindtap="goToPassMap">
      <view class="quick-entry-icon pass">🎯</view>
      <view class="quick-entry-text">
        <view class="quick-entry-title">通关地图</view>
        <view class="quick-entry-desc">查看阶段进度与证书</view>
      </view>
    </view>
  </view>

  <view class="section-header" wx:if="{{passSummary}}">
    <text class="section-title">通关进度</text>
    <text class="section-more" bindtap="goToPassMap">查看全部 →</text>
  </view>

  <view class="pass-summary-card" wx:if="{{passSummary}}" bindtap="goToPassMap">
    <view class="pass-summary-top">
      <view>
        <view class="pass-role">岗位通关路径</view>
        <view class="pass-stats">已通关 {{passSummary.completed_count}} / {{passSummary.total_count}} 阶段</view>
      </view>
      <view class="pass-certs">证书 {{passSummary.certificates}}</view>
    </view>
    <view class="pass-current" wx:if="{{passSummary.active_stage}}">
      <view class="pass-current-label">当前阶段</view>
      <view class="pass-current-name">{{passSummary.active_stage.name}}</view>
      <view class="pass-current-meta">{{passSummary.active_stage.completed_count}} / {{passSummary.active_stage.tasks_count}} 任务 · {{passSummary.active_stage.progress_percent}}%</view>
    </view>
    <view class="pass-stage-list">
      <view class="pass-stage-item {{item.status}}" wx:for="{{passSummary.recent_stages}}" wx:key="id" bindtap="goToPassStage" data-id="{{item.id}}">
        <view class="pass-stage-name">{{item.name}}</view>
        <view class="pass-stage-status">{{item.status_text}}</view>
      </view>
    </view>
  </view>

  <!-- Common Knowledge Section -->
  <view class="section-header">
    <text class="section-title">通用知识</text>
    <text class="section-more" bindtap="goToKnowledge">查看全部 →</text>
  </view>

  <scroll-view scroll-x class="knowledge-scroll" enable-flex>
    <view
      class="knowledge-card"
      wx:for="{{commonKnowledge}}"
      wx:key="id"
      bindtap="goToKnowledgeDetail"
      data-id="{{item.id}}"
    >
      <view class="knowledge-card-title">{{item.title}}</view>
      <view class="knowledge-card-desc">{{item.summary}}</view>
      <view class="knowledge-card-tags">
        <text class="tag">公共</text>
      </view>
    </view>
  </scroll-view>

  <!-- Course Section -->
  <view class="section-header" style="margin-top: 16px;">
    <text class="section-title">课程学习</text>
  </view>

  <view class="category-tabs">
    <scroll-view scroll-x class="scroll-tabs">
      <view
        class="tab-item {{wxs.classIfEq(selectedCategoryId, 0, 'active')}}"
        bindtap="selectCategory"
        data-id="0"
      >全部</view>
      <view
        class="tab-item {{wxs.classIfEq(selectedCategoryId, item.id, 'active')}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="selectCategory"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </scroll-view>
  </view>

  <view class="course-list">
    <view
      class="course-card {{item.status_class}}"
      wx:for="{{courses}}"
      wx:key="id"
      bindtap="goToCourse"
      data-id="{{item.id}}"
    >
      <view class="course-cover" style="{{item.coverStyle}}">
        <view class="cover-overlay">
          <text class="status-text {{item.status_class}}">
            {{item.status_text}}
          </text>
        </view>
        <view class="required-tag" wx:if="{{item.is_required}}">必修</view>
      </view>
      <view class="course-info">
        <view class="course-title">{{item.title}}</view>
        <view class="course-meta">
          <text class="category">{{item.category_name}}</text>
          <text class="duration">{{item.duration}}分钟</text>
        </view>
        <view class="course-footer">
          <text class="points-reward">+{{item.points_reward}}积分</text>
          <text class="difficulty difficulty-{{item.difficulty}}">
            {{item.difficulty_name}}
          </text>
        </view>
        <view class="progress-bar" wx:if="{{wxs.and(item.is_started, wxs.not(item.is_completed))}}">
          <view class="progress-fill" style="width: {{wxs.fallback(item.user_progress, 0)}}%"></view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{wxs.and(wxs.eq(wxs.len(courses), 0), wxs.not(loading))}}">
      <text>暂无课程</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
