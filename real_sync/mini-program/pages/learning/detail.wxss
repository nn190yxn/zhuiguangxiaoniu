.course-header {
  background: #ffffff;
  border-radius: 20px;
  overflow: hidden;
  margin: 16px;
}

.course-cover {
  height: 180px;
  background-size: cover;
  background-position: center;
}

.course-cover-placeholder {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0cc 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.course-cover-icon {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  background: rgba(255,255,255,0.78);
  color: #ff6b35;
  font-size: 24px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.course-info {
  padding: 16px;
}

.course-category {
  display: inline-block;
  font-size: 12px;
  color: #ff6b35;
  background: #fff3e0;
  padding: 4px 12px;
  border-radius: 12px;
  margin-bottom: 10px;
}

.course-title {
  font-size: 20px;
  font-weight: 600;
  color: #1f1a17;
  line-height: 1.45;
  margin-bottom: 12px;
}

.course-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-bottom: 12px;
  line-height: 1.45;
}

.course-meta text {
  font-size: 13px;
  color: #9a958e;
}

.progress-info {
  margin-top: 8px;
}

.progress-text {
  font-size: 13px;
  color: #6b625c;
  margin-bottom: 6px;
  display: block;
}

.progress-bar {
  height: 6px;
  background: #f0f0f0;
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ff6b35;
  border-radius: 3px;
}

.course-section {
  background: #ffffff;
  border-radius: 16px;
  margin: 0 16px 16px;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 12px;
}

.course-desc {
  font-size: 14px;
  color: #6b625c;
  line-height: 1.75;
}

.lesson-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.lesson-item {
  display: flex;
  align-items: center;
  padding: 12px;
  background: #f9f9f9;
  border-radius: 12px;
}

.lesson-item.completed {
  opacity: 0.7;
}

.lesson-number {
  width: 28px;
  height: 28px;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  margin-right: 12px;
}

.lesson-item.completed .lesson-number {
  background: #4caf50;
}

.lesson-info {
  flex: 1;
  min-width: 0;
}

.lesson-title {
  font-size: 14px;
  color: #1f1a17;
  margin-bottom: 2px;
  line-height: 1.45;
}

.lesson-meta {
  font-size: 12px;
  color: #9a958e;
}

.lesson-status {
  margin-left: 12px;
}

.completed-icon {
  color: #4caf50;
  font-size: 18px;
}

.exam-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: #fff3e0;
  border-radius: 12px;
}

.exam-card.passed {
  background: #e8f5e9;
}

.exam-title {
  font-size: 15px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 6px;
}

.exam-meta {
  display: flex;
  gap: 12px;
}

.exam-meta text {
  font-size: 12px;
  color: #6b625c;
}

.passed-tag {
  font-size: 13px;
  color: #4caf50;
  font-weight: 600;
}

.go-exam {
  font-size: 13px;
  color: #ff6b35;
  font-weight: 600;
}
