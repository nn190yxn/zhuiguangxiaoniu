.header-card {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5a 100%);
  border-radius: 20px;
  padding: 20px;
  margin: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 13px;
  color: rgba(255,255,255,0.85);
  margin-bottom: 4px;
}

.points-value {
  font-size: 32px;
  font-weight: 700;
  color: #ffffff;
}

.checkin-btn {
  background: rgba(255,255,255,0.2);
  border-radius: 20px;
  padding: 10px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.checkin-btn.checked {
  background: rgba(255,255,255,0.1);
}

.checkin-text {
  font-size: 14px;
  color: #ffffff;
  font-weight: 600;
}

.checkin-points {
  font-size: 12px;
  color: rgba(255,255,255,0.85);
  margin-top: 2px;
}

.category-tabs {
  padding: 0 16px;
  margin-bottom: 12px;
}

.scroll-tabs {
  white-space: nowrap;
}

.tab-item {
  display: inline-block;
  padding: 8px 16px;
  font-size: 14px;
  color: #6b625c;
  margin-right: 8px;
  border-radius: 16px;
  background: #ffffff;
}

.tab-item.active {
  background: #ff6b35;
  color: #ffffff;
}

.course-list {
  padding: 0 16px;
  padding-bottom: 20px;
}

.course-card {
  background: #ffffff;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.course-cover {
  height: 140px;
  background-size: cover;
  background-position: center;
  position: relative;
}

.course-cover-placeholder {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0cc 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.course-cover-icon {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background: rgba(255,255,255,0.78);
  color: #ff6b35;
  font-size: 22px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8px 12px;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.status-text {
  font-size: 12px;
  color: #ffffff;
}

.status-text.completed {
  color: #4caf50;
}

.required-tag {
  position: absolute;
  top: 12px;
  right: 12px;
  background: #ff6b35;
  color: #ffffff;
  font-size: 11px;
  padding: 4px 8px;
  border-radius: 10px;
}

.course-info {
  padding: 16px;
}

.course-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 8px;
  line-height: 1.5;
}

.course-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 8px;
  line-height: 1.45;
}

.category, .duration {
  font-size: 12px;
  color: #9a958e;
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}

.points-reward {
  font-size: 13px;
  color: #ff6b35;
  flex: 1;
  min-width: 0;
}

.difficulty {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 8px;
}

.difficulty-1 { background: #e8f5e9; color: #4caf50; }
.difficulty-2 { background: #fff3e0; color: #ff9800; }
.difficulty-3 { background: #ffebee; color: #f44336; }

.progress-bar {
  height: 4px;
  background: #f0f0f0;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ff6b35;
  border-radius: 2px;
  transition: width 0.3s;
}

.empty {
  text-align: center;
  padding: 60px 0;
  color: #9a958e;
}

.loading {
  text-align: center;
  padding: 20px 0;
  color: #9a958e;
}

/* Quick Entry */
.quick-entry {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  padding: 0 16px 16px;
}

.quick-entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 104px;
  padding: 12px 8px;
  background: #ffffff;
  border-radius: 12px;
  text-align: center;
}

.quick-entry-icon {
  width: 38px;
  height: 38px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  flex-shrink: 0;
  margin-bottom: 8px;
}

.quick-entry-icon.policy {
  background: linear-gradient(135deg, #ff6b35, #ff8f65);
}

.quick-entry-icon.knowledge {
  background: linear-gradient(135deg, #4caf50, #66bb6a);
}

.quick-entry-text {
  width: 100%;
}

.quick-entry-title {
  font-size: 13px;
  font-weight: 600;
  color: #1f1a17;
  line-height: 1.35;
  margin-bottom: 4px;
}

.quick-entry-desc {
  font-size: 10px;
  color: #9a958e;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Section Header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 16px 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
}

.section-more {
  font-size: 13px;
  color: #9a958e;
}

/* Knowledge Scroll */
.knowledge-scroll {
  padding: 0 16px 4px;
  white-space: nowrap;
}

.knowledge-card {
  display: inline-block;
  width: 224px;
  background: #ffffff;
  border-radius: 12px;
  padding: 14px 14px 12px;
  margin-right: 12px;
  vertical-align: top;
  box-sizing: border-box;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.knowledge-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 12px;
}

.knowledge-icon {
  width: 36px;
  height: 36px;
  border-radius: 12px;
  background: #fff3e0;
  color: #ff6b35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
}

.knowledge-card-title {
  font-size: 15px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.45;
}

.knowledge-card-desc {
  font-size: 12px;
  color: #6b625c;
  line-height: 1.55;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 38px;
}

.knowledge-card-tags {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  justify-content: flex-end;
  flex: 1;
}

.knowledge-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.knowledge-card-link {
  color: #ff6b35;
  font-size: 12px;
  font-weight: 600;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 2px 8px;
  background: #fff3e0;
  color: #ff6b35;
  border-radius: 8px;
  font-size: 10px;
  line-height: 16px;
  flex-shrink: 0;
}

.tag-public {
  background: #e8f5e9;
  color: #4caf50;
}
