.header-card {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5a 100%);
  border-radius: 20px;
  padding: 20px;
  margin: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 13px;
  color: rgba(255,255,255,0.85);
  margin-bottom: 4px;
}

.points-value {
  font-size: 32px;
  font-weight: 700;
  color: #ffffff;
}

.checkin-btn {
  background: rgba(255,255,255,0.2);
  border-radius: 20px;
  padding: 10px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.checkin-btn.checked {
  background: rgba(255,255,255,0.1);
}

.checkin-text {
  font-size: 14px;
  color: #ffffff;
  font-weight: 600;
}

.checkin-points {
  font-size: 12px;
  color: rgba(255,255,255,0.85);
  margin-top: 2px;
}

.category-tabs {
  padding: 0 16px;
  margin-bottom: 12px;
}

.scroll-tabs {
  white-space: nowrap;
}

.tab-item {
  display: inline-block;
  padding: 8px 16px;
  font-size: 14px;
  color: #6b625c;
  margin-right: 8px;
  border-radius: 16px;
  background: #ffffff;
}

.tab-item.active {
  background: #ff6b35;
  color: #ffffff;
}

.course-list {
  padding: 0 16px;
  padding-bottom: 20px;
}

.course-card {
  background: #ffffff;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.course-cover {
  height: 140px;
  background-size: cover;
  background-position: center;
  position: relative;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8px 12px;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.status-text {
  font-size: 12px;
  color: #ffffff;
}

.status-text.completed {
  color: #4caf50;
}

.required-tag {
  position: absolute;
  top: 12px;
  right: 12px;
  background: #ff6b35;
  color: #ffffff;
  font-size: 11px;
  padding: 4px 8px;
  border-radius: 10px;
}

.course-info {
  padding: 16px;
}

.course-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 8px;
  line-height: 1.4;
}

.course-meta {
  display: flex;
  gap: 12px;
  margin-bottom: 8px;
}

.category, .duration {
  font-size: 12px;
  color: #9a958e;
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.points-reward {
  font-size: 13px;
  color: #ff6b35;
}

.difficulty {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 8px;
}

.difficulty-1 { background: #e8f5e9; color: #4caf50; }
.difficulty-2 { background: #fff3e0; color: #ff9800; }
.difficulty-3 { background: #ffebee; color: #f44336; }

.progress-bar {
  height: 4px;
  background: #f0f0f0;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ff6b35;
  border-radius: 2px;
  transition: width 0.3s;
}

.empty {
  text-align: center;
  padding: 60px 0;
  color: #9a958e;
}

.loading {
  text-align: center;
  padding: 20px 0;
  color: #9a958e;
}

/* Quick Entry */
.quick-entry {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding: 0 16px 16px;
}

.quick-entry-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px;
  background: #ffffff;
  border-radius: 12px;
}

.quick-entry-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
}

.quick-entry-icon.policy {
  background: linear-gradient(135deg, #ff6b35, #ff8f65);
}

.quick-entry-icon.knowledge {
  background: linear-gradient(135deg, #4caf50, #66bb6a);
}

.quick-entry-icon.pass {
  background: linear-gradient(135deg, #7b1fa2, #ab47bc);
}

.quick-entry-text {
  flex: 1;
}

.quick-entry-title {
  font-size: 14px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 2px;
}

.quick-entry-desc {
  font-size: 11px;
  color: #9a958e;
}

/* Section Header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 16px 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
}

.section-more {
  font-size: 13px;
  color: #9a958e;
}

/* Knowledge Scroll */
.knowledge-scroll {
  padding: 0 16px;
  white-space: nowrap;
}

.knowledge-card {
  display: inline-block;
  width: 160px;
  background: #ffffff;
  border-radius: 12px;
  padding: 14px;
  margin-right: 12px;
  vertical-align: top;
}

.knowledge-card-title {
  font-size: 14px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 6px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.knowledge-card-desc {
  font-size: 11px;
  color: #9a958e;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 30px;
}

.knowledge-card-tags {
  display: flex;
  gap: 4px;
}

.tag {
  padding: 2px 8px;
  background: #fff3e0;
  color: #ff6b35;
  border-radius: 8px;
  font-size: 10px;
}

/* Pass Summary Card */
.pass-summary-card {
  margin: 0 16px 16px;
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.pass-summary-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.pass-role {
  font-size: 14px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 4px;
}

.pass-stats {
  font-size: 12px;
  color: #9a958e;
}

.pass-certs {
  font-size: 12px;
  color: #ff6b35;
  font-weight: 600;
  padding: 4px 10px;
  background: #fff3e0;
  border-radius: 8px;
  flex-shrink: 0;
}

.pass-current {
  background: #f5f3f0;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 12px;
}

.pass-current-label {
  font-size: 11px;
  color: #9a958e;
  margin-bottom: 4px;
}

.pass-current-name {
  font-size: 16px;
  font-weight: 700;
  color: #1f1a17;
  margin-bottom: 4px;
}

.pass-current-meta {
  font-size: 12px;
  color: #6b625c;
}

.pass-stage-list {
  display: flex;
  flex-wrap: wrap;
}

.pass-stage-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 12px;
  border-radius: 8px;
  background: #faf9f7;
  margin-right: 8px;
  margin-bottom: 8px;
}

.pass-stage-name {
  font-size: 12px;
  color: #1f1a17;
}

.pass-stage-status {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 6px;
  margin-left: 8px;
  flex-shrink: 0;
}

.pass-stage-item.completed .pass-stage-status {
  background: #e8f5e9;
  color: #4caf50;
}

.pass-stage-item.active .pass-stage-status {
  background: #fff3e0;
  color: #ff9800;
}

.pass-stage-item.locked .pass-stage-status {
  background: #f5f5f5;
  color: #bdbdbd;
}
