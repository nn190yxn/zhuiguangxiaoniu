<view class="container">
  <view class="hero-card">
    <view class="hero-title">{{titleText}}</view>
    <view class="hero-desc">{{descText}}</view>
  </view>

  <view class="status-card" wx:if="{{userName}}">当前账号：{{userName}}</view>
  <view class="status-card">{{statusText}}</view>
  <view class="status-card" wx:if="{{debugText}}">调试信息：{{debugText}}</view>

  <view class="rule-card">
    <view class="section-title">当前要求</view>
    <view class="rule-item" wx:if="{{bindMode === 'wecom'}}">登录后先关联当前企业微信成员，再进入提醒授权和首页。</view>
    <view class="rule-item" wx:if="{{bindMode === 'wecom'}}">关联成功后，后续可从企业微信工作台直接进入。</view>
    <view class="rule-item" wx:if="{{bindMode !== 'wecom'}}">登录后先绑定本人微信，再进入提醒授权和首页。</view>
    <view class="rule-item" wx:if="{{bindMode !== 'wecom'}}">绑定成功后，后续可以直接使用微信快捷登录。</view>
  </view>

  <view class="action-card">
    <button wx:if="{{!alreadyBound}}" class="primary-btn" bindtap="startBind" loading="{{loading}}" disabled="{{loading}}">{{actionText}}</button>
    <button wx:else class="primary-btn" bindtap="continueNext" disabled="{{loading}}">继续下一步</button>
    <button class="danger-btn" bindtap="exitLogin" disabled="{{loading}}">退出登录</button>
  </view>
</view>
