<!--pages/survey/fill/fill.wxml-->
<view class="survey-container">
  <!-- 已提交提示 -->
  <view wx:if="{{alreadySubmitted}}" class="submitted-hint">
    <view class="hint-icon">✓</view>
    <view class="hint-text">您已经提交过此问卷</view>
    <button class="hint-btn" bindtap="goHome">返回首页</button>
  </view>

  <block wx:else>
    <!-- 问卷头部 -->
    <view class="survey-header">
      <view class="survey-title">{{survey.title}}</view>
      <view wx:if="{{survey.description}}" class="survey-desc">{{survey.description}}</view>
      <view class="survey-meta">
        <text wx:if="{{isRealNameSurvey}}" class="meta-tag">实名问卷</text>
        <text wx:else class="meta-tag anonymous">匿名问卷</text>
      </view>
    </view>

    <!-- 校区选择 -->
    <view wx:if="{{showCampusSection}}" class="section campus-section" bindtap="showCampusPicker">
      <view class="section-label required">选择校区</view>
      <view class="campus-value">
        <text wx:if="{{selectedCampus}}" class="selected">{{selectedCampus.name}}</text>
        <text wx:else class="placeholder">请选择您所在的校区</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 校区选择弹窗 -->
    <view wx:if="{{showCampusPicker}}" class="picker-mask" bindtap="hideCampusPicker">
      <view class="picker-content" catchtap>
        <view class="picker-header">
          <text class="picker-cancel" bindtap="hideCampusPicker">取消</text>
          <text class="picker-title">选择校区</text>
          <text class="picker-confirm" bindtap="confirmCampus">确定</text>
        </view>
        <picker-view class="picker-view" value="{{campusPickerValue}}" bindchange="onCampusChange" indicator-style="height: 50px;">
          <picker-view-column>
            <view wx:for="{{campuses}}" wx:key="id" class="picker-item">{{item.name}}</view>
          </picker-view-column>
        </picker-view>
      </view>
    </view>

    <!-- 分区 -->
    <view wx:for="{{sections}}" wx:key="title" class="section-group">
      <view wx:if="{{item.showTitle}}" class="section-title-bar">{{item.title}}</view>

      <!-- 题目 -->
      <view wx:for="{{item.questions}}" wx:for-item="q" wx:key="id" class="question-card">
        <view class="question-header">
          <text wx:if="{{q.is_required}}" class="required-mark">*</text>
          <text class="question-text">{{q.question_text}}</text>
        </view>

        <!-- 单选题 -->
        <view wx:if="{{q.isRadio}}" class="options-list">
          <view wx:for="{{q.option_items}}" wx:for-item="opt" wx:key="value"
                class="option-item {{opt.activeClass}}"
                bindtap="onRadioChange" data-id="{{q.id}}" data-value="{{opt.value}}">
            <view class="option-radio">
              <view wx:if="{{opt.checked}}" class="radio-dot"></view>
            </view>
            <text class="option-text">{{opt.value}}</text>
          </view>
        </view>

        <!-- 评分题 -->
        <view wx:if="{{q.isRating}}" class="rating-stars">
          <view wx:for="{{q.rating_items}}" wx:for-item="star" wx:key="score"
                class="star-item {{star.activeClass}}"
                bindtap="onRatingTap" data-id="{{q.id}}" data-score="{{star.score}}">
            <text class="star-icon">{{star.icon}}</text>
            <text class="star-label">{{star.label}}</text>
          </view>
        </view>

        <!-- NPS题 -->
        <view wx:if="{{q.isNps}}" class="nps-scale">
          <view wx:for="{{q.nps_items}}" wx:for-item="n" wx:key="score"
                class="nps-item {{n.activeClass}}"
                bindtap="onRatingTap" data-id="{{q.id}}" data-score="{{n.score}}">
            {{n.score}}
          </view>
          <view class="nps-labels">
            <text>不可能</text>
            <text>极有可能</text>
          </view>
        </view>

        <!-- 多选题 -->
        <view wx:if="{{q.isCheckbox}}" class="options-list">
          <view wx:for="{{q.option_items}}" wx:for-item="opt" wx:key="value"
                class="option-item {{opt.activeClass}}"
                bindtap="onCheckboxChange" data-id="{{q.id}}" data-value="{{opt.value}}">
            <view class="option-checkbox">
              <text wx:if="{{opt.checked}}" class="check-mark">✓</text>
            </view>
            <text class="option-text">{{opt.value}}</text>
          </view>
        </view>

        <!-- 文字题 -->
        <view wx:if="{{q.isText}}" class="text-answer">
          <textarea class="text-input" placeholder="请输入您的回答..."
                    maxlength="500" value="{{q.textValue}}"
                    bindinput="onTextInput" data-id="{{q.id}}" auto-height />
          <view class="char-count">{{q.char_count}}/500</view>
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-area">
      <button class="submit-btn {{submitBtnClass}}"
              bindtap="onSubmit" disabled="{{submitting}}">
        {{submitBtnText}}
      </button>
    </view>
  </block>
</view>
