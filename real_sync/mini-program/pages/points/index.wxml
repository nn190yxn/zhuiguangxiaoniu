<view class="container">
  <view class="points-header">
    <view class="points-balance">
      <text class="balance-label">可用积分</text>
      <text class="balance-value">{{totalPoints}}</text>
    </view>
    <view class="points-actions">
      <button class="btn-checkin {{todayChecked ? 'checked' : ''}}" bindtap="doCheckin" disabled="{{todayChecked}}">
        <text class="checkin-text">{{todayChecked ? '已签到' : '签到'}}</text>
        <text class="checkin-points" wx:if="{{!todayChecked}}">+5</text>
      </button>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-value">{{continuousDays}}</text>
      <text class="stat-label">连续签到</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{accumulatedPoints}}</text>
      <text class="stat-label">累计积分</text>
    </view>
  </view>

  <view class="tabs">
    <view class="tab-item {{activeTab === 'rules' ? 'active' : ''}}" bindtap="switchTab" data-tab="rules">积分规则</view>
    <view class="tab-item {{activeTab === 'records' ? 'active' : ''}}" bindtap="switchTab" data-tab="records">积分记录</view>
    <view class="tab-item {{activeTab === 'exchange' ? 'active' : ''}}" bindtap="switchTab" data-tab="exchange">积分兑换</view>
  </view>

  <view class="tab-content">
    <view class="rules-list" wx:if="{{activeTab === 'rules'}}">
      <view class="rule-item" wx:for="{{rules}}" wx:key="id">
        <view class="rule-info">
          <view class="rule-name">{{item.name}}</view>
          <view class="rule-desc">{{item.description}}</view>
        </view>
        <view class="rule-points {{item.points > 0 ? 'earn' : 'spend'}}">
          {{item.points > 0 ? '+' : ''}}{{item.points}}
        </view>
      </view>
      <view class="empty" wx:if="{{rules.length === 0}}">
        <text>暂无规则</text>
      </view>
    </view>

    <view class="records-list" wx:if="{{activeTab === 'records'}}">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-info">
          <view class="record-name">{{item.description || item.rule_name}}</view>
          <view class="record-time">{{item.created_at}}</view>
        </view>
        <view class="record-points {{item.points > 0 ? 'earn' : 'spend'}}">
          {{item.points_display}}
        </view>
      </view>
      <view class="loading" wx:if="{{loadingRecords}}">
        <text>加载中...</text>
      </view>
      <view class="empty" wx:if="{{records.length === 0 && !loadingRecords}}">
        <text>暂无记录</text>
      </view>
    </view>

    <view class="exchange-list" wx:if="{{activeTab === 'exchange'}}">
      <view class="exchange-item" wx:for="{{exchangeItems}}" wx:key="id">
        <view class="exchange-cover" style="background-image: url('{{item.cover_image}}')"></view>
        <view class="exchange-info">
          <view class="exchange-title">{{item.title}}</view>
          <view class="exchange-desc">{{item.description}}</view>
          <view class="exchange-footer">
            <text class="exchange-points">{{item.points_price}}积分</text>
            <text class="exchange-stock">库存: {{item.stock}}</text>
          </view>
        </view>
        <button
          class="btn-exchange {{totalPoints < item.points_price ? 'disabled' : ''}}"
          bindtap="openExchange"
          data-id="{{item.id}}"
          data-title="{{item.title}}"
          data-points="{{item.points_price}}"
          disabled="{{totalPoints < item.points_price}}"
        >兑换</button>
      </view>
      <view class="empty" wx:if="{{exchangeItems.length === 0}}">
        <text>暂无可兑换礼品</text>
      </view>
    </view>
  </view>
</view>

<view class="modal {{showModal ? 'show' : ''}}" wx:if="{{showModal}}">
  <view class="modal-mask" bindtap="closeModal"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">兑换礼品</text>
    </view>
    <view class="exchange-preview">
      <view class="preview-title">{{selectedItem.title}}</view>
      <view class="preview-points">{{selectedItem.points}}积分</view>
    </view>
    <form class="exchange-form" bindsubmit="submitExchange">
      <input name="receiver_name" placeholder="收货人姓名" value="{{formData.receiver_name}}" />
      <input name="receiver_phone" placeholder="联系电话" type="tel" value="{{formData.receiver_phone}}" />
      <textarea name="receiver_address" placeholder="收货地址" value="{{formData.receiver_address}}"></textarea>
      <view class="form-actions">
        <button type="button" class="btn-secondary" bindtap="closeModal">取消</button>
        <button type="submit" class="btn-primary">确认兑换</button>
      </view>
    </form>
  </view>
</view>