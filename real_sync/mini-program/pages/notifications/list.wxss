.notification-list {
  padding-bottom: 20px;
}

.notification-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.notification-card.unread {
  border-left: 4px solid #ff6b35;
}

.notification-card.confirmed {
  opacity: 0.7;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}

.notification-type {
  font-size: 12px;
  color: #6b625c;
  background: rgba(0,0,0,0.05);
  padding: 4px 10px;
  border-radius: 12px;
}

.notification-type.reminder {
  background: #fff3e0;
  color: #ff6b35;
}

.notification-time {
  font-size: 12px;
  color: #9a958e;
  flex-shrink: 0;
  text-align: right;
}

.notification-title {
  font-size: 15px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 8px;
  line-height: 1.55;
}

.notification-content {
  font-size: 13px;
  color: #6b625c;
  line-height: 1.65;
  margin-bottom: 12px;
}

.notification-actions {
  display: flex;
  justify-content: flex-end;
}

.btn-confirm {
  font-size: 13px;
  color: #ff6b35;
  padding: 6px 16px;
  border: 1px solid #ff6b35;
  border-radius: 16px;
}

.notification-status {
  font-size: 12px;
  color: #4caf50;
  text-align: right;
}

.empty {
  text-align: center;
  padding: 60px 0;
  color: #9a958e;
  font-size: 14px;
}

.loading {
  text-align: center;
  padding: 20px 0;
  color: #9a958e;
  font-size: 13px;
}
