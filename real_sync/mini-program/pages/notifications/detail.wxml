<wxs src="../../utils/wxml.wxs" module="wxs" />

<view class="container">
  <view class="notification-header">
    <view class="notification-type {{wxs.classIfEq(notification.type, 'reminder', 'reminder')}}">
      {{notification.typeName}}
    </view>
    <view class="notification-time">{{notification.created_at}}</view>
  </view>

  <view class="notification-title">{{notification.title}}</view>

  <view class="notification-content" wx:if="{{notification.content}}">
    {{notification.content}}
  </view>

  <view class="notification-status" wx:if="{{notification.is_confirmed}}">
    ✓ 已确认阅读
  </view>

  <view class="action-bar" wx:if="{{wxs.and(wxs.eq(notification.type, 'confirm'), wxs.not(notification.is_confirmed))}}">
    <button class="btn-confirm" bindtap="confirmRead">确认阅读</button>
  </view>
</view>
