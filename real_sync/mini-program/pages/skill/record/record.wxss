.container {
  min-height: 100vh;
  background: #f5f3f0;
  padding-bottom: 40px;
}

.header {
  padding: 32px 20px 24px;
  text-align: center;
}

.title {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #1f1a17;
  margin-bottom: 8px;
}

.desc {
  display: block;
  font-size: 14px;
  color: #6b625c;
}

.scene-section {
  padding: 0 16px;
  margin-bottom: 16px;
}

.section-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 12px;
}

.scene-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.scene-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: #ffffff;
  border-radius: 12px;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.scene-item.active {
  border-color: #ff6b35;
  background: #fff8f5;
}

.scene-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.scene-icon.new-sale {
  background: linear-gradient(135deg, #ff6b35, #ff8f5a);
}

.scene-icon.renewal {
  background: linear-gradient(135deg, #4caf50, #66bb6a);
}

.scene-icon.assessment {
  background: linear-gradient(135deg, #2196f3, #42a5f5);
}

.scene-info {
  flex: 1;
}

.scene-name {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 4px;
}

.scene-desc {
  display: block;
  font-size: 12px;
  color: #9a958e;
}

.record-section {
  padding: 0 16px;
}

.record-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 24px;
  text-align: center;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 120px;
  height: 120px;
  margin: 0 auto;
  border-radius: 60px;
  background: linear-gradient(135deg, #ff6b35, #ff8f5a);
  transition: all 0.2s;
}

.record-btn.recording {
  background: linear-gradient(135deg, #dc2626, #ef4444);
}

.record-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.record-icon {
  font-size: 32px;
}

.recording-indicator {
  display: flex;
  gap: 6px;
  align-items: center;
}

.pulse {
  width: 8px;
  height: 8px;
  background: #ffffff;
  border-radius: 4px;
  animation: pulse 0.6s ease-in-out infinite;
}

.pulse:nth-child(2) {
  animation-delay: 0.2s;
}

.pulse:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes pulse {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(2); }
}

.record-text {
  font-size: 14px;
  font-weight: 600;
  color: #ffffff;
}

.record-time {
  margin-top: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.time-value {
  font-size: 28px;
  font-weight: 700;
  color: #ff6b35;
}

.time-label {
  font-size: 12px;
  color: #9a958e;
  margin-top: 4px;
}

.record-tip {
  margin-top: 16px;
  font-size: 12px;
  color: #9a958e;
}

.upload-section {
  margin-top: 20px;
  padding: 0 16px;
}

.btn-upload {
  width: 100%;
  height: 50px;
  border-radius: 25px;
  background: #ff6b35;
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
  border: none;
}

.btn-upload:active {
  opacity: 0.9;
}

.btn-upload.disabled,
.btn-upload[disabled] {
  background: #ccc;
}

.upload-tip {
  display: block;
  text-align: center;
  margin-top: 12px;
  font-size: 13px;
  color: #dc2626;
}

.error-msg {
  background: #fef2f2;
  color: #dc2626;
  padding: 12px 16px;
  border-radius: 8px;
  font-size: 13px;
  margin-top: 16px;
  text-align: center;
}

.history-link {
  padding: 24px 16px;
  text-align: center;
}

.link-text {
  font-size: 14px;
  color: #ff6b35;
  font-weight: 500;
}