<view class="container">
  <view class="filter-section">
    <view class="filter-tabs">
      <view class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" bindtap="changeFilter" data-filter="all">
        <text>全部</text>
      </view>
      <view class="filter-tab {{currentFilter === 'new_sale' ? 'active' : ''}}" bindtap="changeFilter" data-filter="new_sale">
        <text>新签</text>
      </view>
      <view class="filter-tab {{currentFilter === 'renewal' ? 'active' : ''}}" bindtap="changeFilter" data-filter="renewal">
        <text>续费</text>
      </view>
      <view class="filter-tab {{currentFilter === 'assessment' ? 'active' : ''}}" bindtap="changeFilter" data-filter="assessment">
        <text>体测</text>
      </view>
    </view>
  </view>

  <view class="list-section">
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <view wx:if="{{!loading && records.length === 0}}" class="empty">
      <text class="empty-text">暂无复盘记录</text>
      <button class="btn-record" bindtap="goToRecord">开始录音复盘</button>
    </view>

    <view wx:for="{{records}}" wx:key="id" class="record-item" bindtap="viewDetail" data-id="{{item.id}}">
      <view class="record-header">
        <view class="scene-badge {{item.scene_type}}">
          <text>{{item.sceneName}}</text>
        </view>
        <text class="record-date">{{item.createdAt}}</text>
      </view>

      <view class="record-body">
        <view class="score-display">
          <view class="score-circle {{item.level}}">
            <text class="score-num">{{item.ai_score || '--'}}</text>
          </view>
          <view class="score-meta">
            <text class="score-level">{{item.ai_level || '处理中'}}</text>
            <text class="score-status">{{item.statusText}}</text>
          </view>
        </view>
      </view>

      <view class="record-footer">
        <text class="view-detail">查看详情 →</text>
      </view>
    </view>
  </view>
</view>