.container {
  min-height: 100vh;
  background: #f5f3f0;
}

.filter-section {
  padding: 16px;
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-tabs {
  display: flex;
  gap: 8px;
}

.filter-tab {
  flex: 1;
  height: 36px;
  border-radius: 18px;
  background: #f5f3f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: #6b625c;
  transition: all 0.2s;
}

.filter-tab.active {
  background: #ff6b35;
  color: #ffffff;
}

.list-section {
  padding: 16px;
}

.loading {
  padding: 60px 0;
  text-align: center;
  color: #9a958e;
  font-size: 14px;
}

.empty {
  padding: 60px 0;
  text-align: center;
}

.empty-text {
  display: block;
  font-size: 14px;
  color: #9a958e;
  margin-bottom: 20px;
}

.btn-record {
  width: 160px;
  height: 44px;
  border-radius: 22px;
  background: #ff6b35;
  color: #ffffff;
  font-size: 15px;
  border: none;
}

.record-item {
  background: #ffffff;
  border-radius: 12px;
  margin-bottom: 12px;
}

.record-header {
  padding: 12px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #f5f3f0;
}

.scene-badge {
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
}

.scene-badge.new_sale {
  background: #fff3e0;
  color: #ff6b35;
}

.scene-badge.renewal {
  background: #e8f5e9;
  color: #4caf50;
}

.scene-badge.assessment {
  background: #e3f2fd;
  color: #2196f3;
}

.record-date {
  font-size: 12px;
  color: #9a958e;
}

.record-body {
  padding: 16px;
}

.score-display {
  display: flex;
  align-items: center;
  gap: 16px;
}

.score-circle {
  width: 48px;
  height: 48px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-circle.优秀 {
  background: linear-gradient(135deg, #4caf50, #66bb6a);
}

.score-circle.良好 {
  background: linear-gradient(135deg, #2196f3, #42a5f5);
}

.score-circle.合格 {
  background: linear-gradient(135deg, #ff9800, #ffb74d);
}

.score-circle.不合格 {
  background: linear-gradient(135deg, #f44336, #ef5350);
}

.score-circle.default {
  background: linear-gradient(135deg, #9e9e9e, #bdbdbd);
}

.score-num {
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
}

.score-meta {
  flex: 1;
}

.score-level {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 4px;
}

.score-status {
  display: block;
  font-size: 12px;
  color: #9a958e;
}

.record-footer {
  padding: 12px 16px;
  border-top: 1px solid #f5f3f0;
  text-align: center;
}

.view-detail {
  font-size: 14px;
  color: #ff6b35;
}