<view class="container">
  <view class="status-section" wx:if="{{status !== 'completed'}}">
    <view class="status-card">
      <view class="status-icon {{status}}">
        <text wx:if="{{status === 'pending'}}">⏳</text>
        <text wx:if="{{status === 'transcribing'}}">🎙️</text>
        <text wx:if="{{status === 'analyzing'}}">🤖</text>
        <text wx:if="{{status === 'failed'}}">❌</text>
      </view>
      <text class="status-text">{{statusText}}</text>
      <text class="status-desc">{{statusDesc}}</text>
    </view>
  </view>

  <view class="result-section" wx:if="{{status === 'completed'}}">
    <view class="score-card">
      <view class="score-circle {{scoreLevel}}">
        <text class="score-value">{{aiScore}}</text>
        <text class="score-label">分</text>
      </view>
      <view class="score-info">
        <text class="score-level">{{aiLevel}}</text>
        <text class="scene-name">{{sceneName}}</text>
      </view>
    </view>

    <view class="report-section">
      <view class="report-header">
        <text class="report-title">AI 分析报告</text>
      </view>
      <view class="report-content">
        <text class="report-text">{{aiReport}}</text>
      </view>
    </view>

    <view class="transcript-section">
      <view class="transcript-header" bindtap="toggleTranscript">
        <text class="transcript-title">录音转写文本</text>
        <text class="transcript-toggle">{{showTranscript ? '收起' : '展开'}}</text>
      </view>
      <view class="transcript-content" wx:if="{{showTranscript}}">
        <text class="transcript-text">{{transcriptText}}</text>
      </view>
    </view>
  </view>

  <view class="error-section" wx:if="{{status === 'failed'}}">
    <view class="error-card">
      <text class="error-title">处理失败</text>
      <text class="error-msg">{{errorMessage}}</text>
    </view>
  </view>

  <view class="actions">
    <button class="btn-retry" wx:if="{{status === 'failed'}}" bindtap="goBack">返回重新录音</button>
    <button class="btn-history" bindtap="goToHistory">查看历史记录</button>
  </view>
</view>