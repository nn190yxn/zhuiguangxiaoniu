.container {
  min-height: 100vh;
  background: #f5f3f0;
  padding-bottom: 40px;
}

.status-section {
  padding: 60px 16px;
}

.status-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 40px 24px;
  text-align: center;
}

.status-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.status-text {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 8px;
}

.status-desc {
  display: block;
  font-size: 14px;
  color: #9a958e;
}

.result-section {
  padding: 16px;
}

.score-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 16px;
}

.score-circle {
  width: 80px;
  height: 80px;
  border-radius: 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-circle.优秀 {
  background: linear-gradient(135deg, #4caf50, #66bb6a);
}

.score-circle.良好 {
  background: linear-gradient(135deg, #2196f3, #42a5f5);
}

.score-circle.合格 {
  background: linear-gradient(135deg, #ff9800, #ffb74d);
}

.score-circle.不合格 {
  background: linear-gradient(135deg, #f44336, #ef5350);
}

.score-circle.default {
  background: linear-gradient(135deg, #9e9e9e, #bdbdbd);
}

.score-value {
  font-size: 28px;
  font-weight: 700;
  color: #ffffff;
}

.score-label {
  font-size: 12px;
  color: rgba(255,255,255,0.8);
}

.score-info {
  flex: 1;
}

.score-level {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #1f1a17;
  margin-bottom: 4px;
}

.scene-name {
  display: block;
  font-size: 14px;
  color: #9a958e;
}

.report-section {
  background: #ffffff;
  border-radius: 16px;
  margin-bottom: 16px;
}

.report-header {
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.report-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
}

.report-content {
  padding: 16px 20px;
}

.report-text {
  font-size: 14px;
  color: #4a4540;
  line-height: 1.8;
  white-space: pre-wrap;
}

.transcript-section {
  background: #ffffff;
  border-radius: 16px;
}

.transcript-header {
  padding: 16px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #f0f0f0;
}

.transcript-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f1a17;
}

.transcript-toggle {
  font-size: 14px;
  color: #ff6b35;
}

.transcript-content {
  padding: 16px 20px;
}

.transcript-text {
  font-size: 14px;
  color: #6b625c;
  line-height: 1.8;
  white-space: pre-wrap;
}

.error-section {
  padding: 60px 16px;
}

.error-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 40px 24px;
  text-align: center;
}

.error-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #dc2626;
  margin-bottom: 16px;
}

.error-msg {
  display: block;
  font-size: 14px;
  color: #6b625c;
}

.actions {
  padding: 24px 16px;
}

.btn-retry {
  width: 100%;
  height: 50px;
  border-radius: 25px;
  background: #ff6b35;
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
  border: none;
  margin-bottom: 12px;
}

.btn-history {
  width: 100%;
  height: 50px;
  border-radius: 25px;
  background: #ffffff;
  color: #ff6b35;
  font-size: 16px;
  font-weight: 600;
  border: 1px solid #ff6b35;
}