.container {
  min-height: 100vh;
  background: #f5f3f0;
}

.logo-section {
  padding: 80px 20px 40px;
  text-align: center;
}

.logo {
  width: 82px;
  height: 82px;
  margin: 0 auto 16px;
  border-radius: 16px;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 800;
}

.app-name {
  font-size: 24px;
  font-weight: 800;
  color: #1f1a17;
}

.app-desc {
  font-size: 14px;
  color: #6b625c;
  margin-top: 4px;
}

.login-form {
  padding: 0 20px;
}

.form-card {
  background: white;
  border-radius: 24px;
  padding: 24px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
}

.form-title {
  font-size: 20px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 24px;
}

.error-msg {
  background: #fef2f2;
  color: #dc2626;
  padding: 12px 16px;
  border-radius: 8px;
  font-size: 13px;
  margin-bottom: 16px;
}

.agreement-box {
  background: #fff8f4;
  border: 1px solid #ffe0d1;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 16px;
}

.agreement-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4px;
  font-size: 12px;
  color: #4a403a;
  line-height: 1.7;
}

.agreement-link {
  color: #ff6b35;
  font-weight: 700;
}

.agreement-tip {
  margin-top: 8px;
  font-size: 12px;
  color: #7a6d65;
  line-height: 1.5;
}

.btn-wechat {
  width: 100%;
  height: 50px;
  border-radius: 25px;
  background: #07c160;
  color: white;
  font-size: 16px;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
}

.btn-wechat:active {
  opacity: 0.9;
}

.btn-wechat[disabled] {
  background: #a6d4ba;
}

.wechat-icon {
  width: 24px;
  height: 24px;
  margin-right: 8px;
  border-radius: 12px;
  background: #ffffff;
  color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 800;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 20px;
}

.divider-line {
  flex: 1;
  height: 1px;
  background: rgba(0,0,0,0.1);
}

.divider-text {
  padding: 0 12px;
  font-size: 13px;
  color: #6b625c;
}

.input-group {
  margin-bottom: 16px;
}

.input-label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #6b625c;
  margin-bottom: 8px;
}

.input {
  width: 100%;
  height: 48px;
  border: 1px solid rgba(0,0,0,0.1);
  border-radius: 12px;
  padding: 0 16px;
  font-size: 15px;
  box-sizing: border-box;
}

.input:focus {
  border-color: #ff6b35;
}

.btn-login {
  width: 100%;
  height: 50px;
  border-radius: 25px;
  background: #ff6b35;
  color: white;
  font-size: 16px;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8px;
}

.btn-login:active {
  opacity: 0.9;
}

.btn-login[disabled] {
  background: #ccc;
}

.loading {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(255,255,255,0.3);
  border-radius: 50%;
  border-top-color: white;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.hint {
  text-align: center;
  margin-top: 20px;
  font-size: 13px;
  color: #6b625c;
  line-height: 1.6;
}
