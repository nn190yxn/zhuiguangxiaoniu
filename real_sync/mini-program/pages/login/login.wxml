<view class="container">
  <view class="logo-section">
    <view class="logo">牛</view>
    <view class="app-name">追光小牛</view>
    <view class="app-desc">员工内网工作台</view>
  </view>

  <view class="login-form">
    <view class="form-card">
      <view class="form-title">员工登录</view>
      <view class="form-subtitle">请使用员工手机号/账号和密码登录</view>

      <view class="error-msg" wx:if="{{errorMsg}}">{{errorMsg}}</view>

      <button class="btn-wechat" bindtap="doWeChatLogin" disabled="{{loading}}">
        <text class="wechat-icon">微</text>
        <text>微信一键登录（需先绑定）</text>
      </button>

      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">或使用账号密码</text>
        <view class="divider-line"></view>
      </view>

      <view class="input-group">
        <label class="input-label">账号</label>
        <input
          class="input"
          type="text"
          placeholder="请输入手机号或员工账号"
          value="{{username}}"
          bindinput="onUsernameInput"
          autocomplete="username"
        />
      </view>

      <view class="input-group">
        <label class="input-label">密码</label>
        <input
          class="input"
          type="password"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
          autocomplete="current-password"
        />
      </view>

      <button class="btn-login" bindtap="doLogin" disabled="{{loading}}">
        <text wx:if="{{loading}}" class="loading"></text>
        <text wx:else>登录</text>
      </button>

      <view class="hint">
        初始密码通常为 123456；如无法登录，请联系管理员重置或绑定微信。
      </view>
    </view>
  </view>
</view>
