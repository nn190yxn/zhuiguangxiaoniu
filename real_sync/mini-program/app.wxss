page {
  font-family: Inter, -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 14px;
  color: #1f1a17;
  background-color: #f5f3f0;
  line-height: 1.6;
}

view,
button,
input,
textarea,
rich-text {
  box-sizing: border-box;
}

.text-wrap {
  overflow-wrap: break-word;
  word-break: break-word;
}

.markdown-content {
  display: block;
  font-size: 15px;
  line-height: 1.78;
  color: #1f1a17;
  overflow-wrap: break-word;
  word-break: break-word;
}

.markdown-content .markdown-heading {
  display: block;
  color: #1f1a17;
  font-weight: 700;
  line-height: 1.38;
  margin: 18px 0 8px;
}

.markdown-content .markdown-h1 {
  font-size: 19px;
}

.markdown-content .markdown-h2 {
  font-size: 17px;
}

.markdown-content .markdown-h3 {
  font-size: 16px;
}

.markdown-content .markdown-paragraph,
.markdown-content .markdown-list-line {
  display: block;
  margin: 0 0 12px;
  color: #2d2621;
}

.markdown-content .markdown-list-line {
  padding-left: 2px;
}

.markdown-content .markdown-quote {
  display: block;
  margin: 12px 0;
  padding: 10px 12px;
  background: #fff8f3;
  border-left: 3px solid #ff6b35;
  color: #6b625c;
}

.markdown-content .markdown-table-block,
.markdown-content .markdown-code-block {
  display: block;
  margin: 12px 0;
  padding: 10px 12px;
  background: #faf7f3;
  border-radius: 12px;
}

.markdown-content .markdown-field {
  display: block;
  padding: 8px 0;
  border-bottom: 1px solid #eee8e2;
}

.markdown-content .markdown-field-label {
  display: block;
  margin-bottom: 3px;
  color: #8a8179;
  font-size: 12px;
  line-height: 1.35;
}

.markdown-content .markdown-field-value {
  display: block;
  color: #1f1a17;
  font-size: 14px;
  line-height: 1.6;
}

.markdown-content .markdown-strong {
  font-weight: 700;
  color: #1f1a17;
}

.markdown-content .markdown-code {
  padding: 2px 4px;
  border-radius: 4px;
  background: #f5f3f0;
  color: #6b625c;
}

.markdown-content .markdown-divider {
  height: 1px;
  margin: 16px 0;
  background: #eee8e2;
  border: 0;
}

button {
  line-height: 1.35;
}

.container {
  min-height: 100vh;
  padding: 16px;
  box-sizing: border-box;
}

/* Card */
.card {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

/* Button */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44px;
  padding: 0 24px;
  border-radius: 22px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  cursor: pointer;
}

.btn-primary {
  background: #ff6b35;
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-secondary {
  background: rgba(0,0,0,0.05);
  color: #6b625c;
}

/* Form */
.input {
  width: 100%;
  height: 48px;
  border: 1px solid rgba(0,0,0,0.1);
  border-radius: 12px;
  padding: 0 16px;
  font-size: 15px;
  box-sizing: border-box;
}

.input:focus {
  border-color: #ff6b35;
}

/* Flex */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Gap */
.gap-8 { gap: 8px; }
.gap-12 { gap: 12px; }
.gap-16 { gap: 16px; }

/* Margin */
.mt-8 { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mb-8 { margin-bottom: 8px; }
.mb-12 { margin-bottom: 12px; }
.mb-16 { margin-bottom: 16px; }

/* Text */
.text-primary { color: #ff6b35; }
.text-muted { color: #6b625c; }
.text-sm { font-size: 12px; }
.text-md { font-size: 14px; }
.text-lg { font-size: 16px; }
.text-xl { font-size: 18px; }
.text-bold { font-weight: 600; }
.text-center { text-align: center; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.text-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
