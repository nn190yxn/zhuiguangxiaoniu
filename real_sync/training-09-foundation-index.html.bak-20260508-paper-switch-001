<script>
const SLIDES = [{"num": 1, "title": "追光小牛销售基础专业培训", "content": "让销售听得懂专业、说得出专业、接得住反馈、转得动课程\n课程顾问 · 店长 · 讲师通用版\nFAB专业表达体系 | ACE运动成长框架 | 体测解读标准化\n2025 追光小牛内部培训专用"}, {"num": 2, "title": "为什么要做这套培训", "content": "从问题出发，找到统一解法\n当前 4 个问题\n● 1. 会接待，不会讲专业 —— 家长问深了就接不住\n● 2. 会报项目，不会讲逻辑 —— 课程推荐像在“卖课”\n● 3. 教练讲完，接不住 —— 反馈到推荐断层\n● 4. 课程推荐像卖课 —— 家长感受不到专业价值\n培训要解决的 4 个结果\n● 1. 统一口径 —— 所有人讲同一套专业语言\n● 2. 专业表达 —— 用 FAB 结构讲清每个卖点\n● 3. 协同能力 —— 销售+教练配合无缝衔接\n● 4. 可复制机制 —— 新人也能快速上手\n➡\n核心目标：让每一位家长在门店感受到的专业是一致的\n不是培训“话术”，而是培训“专业理解力+结构化表达力”"}, {"num": 3, "title": "培训目标总览", "content": "四大核心能力，层层递进\n01\n听得懂专业\n理解体测数据、ACE体系、七大素质等专业概念\n02\n说得出专业\n用 FAB 结构向家长讲清楚课程价值\n03\n接得住教练反馈\n听懂教练评估，自然过渡到课程推荐\n04\n转得动课程方案\n根据孩子情况匹配课程，给出清晰路径\n➡\n➡\n➡\n四大能力构成完整销售专业闭环\n从理解到表达，从承接推荐到方案转化，缺一不可"}, {"num": 4, "title": "销售与教练的边界", "content": "明确职责，专业协作\n✅ 销售可以做\n✔ 讲表现：描述孩子课堂上的行为\n✔ 讲基础影响：解释素质与成长的关系\n✔ 讲训练方向：说明课程训练重点\n✔ 讲课程建议：根据情况推荐课程\n❌ 销售不能做\n✘ 不下诊断：不判断孩子“有什么问题”\n✘ 不做正式评估：体测由教练执行\n✘ 不说肯定怎样：避免绝对化承诺\n✘ 不做结果承诺：不说“保证有效”\n🎓 教练主责\n▶ 执行体测与正式评估\n▶ 给出专业训练建议\n▶ 跟踪训练效果与调整\n边界原则：销售讲“现象与方向”，教练讲“诊断与方案”\n越界不是{LQ}专业{RQ}，而是{LQ}不专业{RQ}的表现"}, {"num": 5, "title": "品牌总口径", "content": "统一对外表达，建立专业认知\n运动成长课是每个孩子的必修课\nF1\n卖的不是单节课\n而是一套运动成长方案\n从“卖课”到“给方案”，家长感受完全不同\nF2\n先体测再建议课程\n用数据说话，让家长信服\n体测是专业入口，不是销售手段\nF3\n门店核心价值\n判断 + 承接 + 反馈 + 陪伴\n四个关键词定义门店角色\n统一口径 = 家长在任何门店听到的都是同一套专业表达"}, {"num": 6, "title": "ACE体系", "content": "运动成长三大维度\nA\nAthletic\n运动能力\n力量、速度、灵敏、协调、平衡、柔韧、耐力\nC\nCognitive\n认知能力\n专注力、判断力、空间感知、问题解决\nE\nEngagement\n参与度\n主动性、社交能力、自信心、抗挫折\n家长语言版翻译\n★ A —— 练好身体：跑得快、跳得高、不容易受伤\n★ C —— 开发大脑：更专注、反应快、会思考\n★ E —— 爱上运动：主动参与、不怕困难、交到朋友"}, {"num": 7, "title": "课程全景图", "content": "五门课程，覆盖全龄段运动成长需求\n01\n快乐体操\n3-6岁基础运动启蒙\n02\n体能训练课\n全龄段综合体能提升\n03\n体能强化课\n进阶体能，突破瓶颈\n04\n体能跳绳课\n专项体能+跳绳技能\n05\n增高体能课\n身高管理+体态优化\n课程推荐原则：先体测，再匹配，给家长讲清楚“为什么推荐这门课”\n每门课都有明确的训练目标和适用场景，不是{LQ}什么都行{RQ}"}, {"num": 8, "title": "课程推荐逻辑总图", "content": "四步推荐法，科学匹配课程\nSTEP 1\n看年龄\n确定基础年龄段范围\n➡\nSTEP 2\n看表现\n观察课堂/日常行为\n➡\nSTEP 3\n看家长目标\n了解家长最关心什么\n➡\nSTEP 4\n课程分流\n匹配最合适的课程\n5 种常见匹配逻辑\n▶ 3-6岁 + 运动基础弱 → 快乐体操\n▶ 全龄 + 综合体能提升 → 体能训练课\n▶ 有基础 + 需要突破 → 体能强化课\n▶ 跳绳不过关 + 体能待提升 → 体能跳绳课\n▶ 身高关注 + 体态问题 → 增高体能课"}, {"num": 9, "title": "七大身体素质为什么重要", "content": "从家长看到的表象，到销售要懂的基础\n家长看到的 5 种表现\n跑不快、跳不高\n容易摔倒、动作笨拙\n坐不住、注意力差\n胆子小、不敢尝试\n体能差、容易累\n销售要听懂的 7 大基础\n力量 —— 肌肉发力与控制\n速度 —— 快速移动与反应\n灵敏 —— 快速变向与躲闪\n协调 —— 多动作配合流畅\n平衡 —— 身体稳定与控制\n柔韧 —— 关节活动范围\n耐力 —— 持续运动能力\n学习目的\n判断：能识别素质短板\n翻译：用家长语言解释\n承接：自然过渡到课程\n七大素质是运动能力的地基\n家长看到的是“结果”，销售要讲出“原因”，才能让家长信服"}, {"num": 10, "title": "力量与速度", "content": "七大素质详解（一）\n力量 Strength\n在看什么：肌肉发力能力与控制力\n\n4 种常见表现：\n● 跳跃时腿软、起跳无力\n● 攀爬时手臂撑不住\n● 跑步时步伐沉重\n● 投掷时距离短、力度小\n\n家长语言：“孩子力气小、没劲儿”\n速度 Speed\n在看什么：快速移动与反应能力\n\n3 种常见表现：\n● 跑步比别人慢\n● 反应迟钝、跟不上节奏\n● 短距离冲刺明显吃力\n\n家长语言：“孩子跑得慢、反应慢”\nF\n力量/速度是基础运动素质\nA\n影响运动表现和自信心\nB\n训练后运动能力明显提升"}, {"num": 11, "title": "灵敏、协调、平衡", "content": "七大素质详解（二）\n灵敏 Agility\n快速变向、躲闪、反应\n关键词：快、灵、变\n表现：躲闪慢、变向笨、追不上球\n家长语言：“孩子反应慢、不灵活”\n协调 Coordination\n多动作配合流畅\n关键词：配合、流畅、同步\n表现：手脚不配合、动作生硬\n家长语言：“孩子动作不协调”\n平衡 Balance\n身体稳定与控制\n关键词：稳、控制、不倒\n表现：容易摔倒、站不稳\n家长语言：“孩子平衡差、老摔跤”"}, {"num": 12, "title": "柔韧与耐力", "content": "七大素质详解（三）\n柔韧 Flexibility\n在看什么：关节活动范围与肌肉伸展性\n\n3 种常见表现：\n● 坐位体前屈够不到脚\n● 动作幅度小、伸展不开\n● 容易拉伤、肌肉紧绷\n\n家长语言：“孩子身体硬、不够软”\n耐力 Endurance\n在看什么：持续运动能力与恢复速度\n\n3 种常见表现：\n● 运动一会儿就喊累\n● 长时间活动后体力不支\n● 运动后恢复慢、第二天还累\n\n家长语言：“孩子体能差、容易累”\n七大素质互相影响，一个短板可能牵连多个表现 —— 这就是为什么需要系统训练"}, {"num": 13, "title": "为什么体测一定要分龄讲", "content": "不同年龄段，体测解读重点完全不同\n3-6岁 低龄逻辑\n1. 重点看基础能力是否建立\n2. 关注感统发展和动作模式\n3. 不比数据，看趋势和参与度\n7-12岁 高龄逻辑\n1. 重点看各项素质的具体水平\n2. 关注体育成绩和运动表现\n3. 可以横向对比同龄标准\n统一结论\n低龄讲“基础建立”，高龄讲“水平提升”\n用错年龄段的讲法，家长会觉得“不专业”\n分龄讲 = 体现对儿童发展规律的理解"}, {"num": 14, "title": "3~6岁体测解读主线", "content": "低龄重点：看基础、看趋势、看参与\n01\n感统基础\n前庭觉、本体觉、触觉发展是否正常\n02\n动作建立\n跑、跳、投、攀等基础动作是否掌握\n03\n参与感与胆量\n是否愿意参与、敢不敢尝试新动作\n04\n规则适应\n能否听指令、遵守课堂规则\n统一讲法：“XX方面正在建立中，通过系统训练可以很好地发展”"}, {"num": 15, "title": "3~6岁重点项目示例", "content": "三个典型体测项目的解读方法\n双脚连续跳\n看什么：下肢力量 + 协调性\n怎么讲：连续跳跃需要腿部力量和身体配合\n家长语言：“孩子跳的时候能看出腿部力量和协调性”\n\n看什么：平衡 + 专注力 + 胆量\n怎么讲：走平衡木考验身体稳定和心理素质\n家长语言：“平衡木能看出孩子稳不稳、敢不敢”\n统一结论\n低龄不讲“分数”，讲“发展状态” —— 让家长看到训练的必要性，而不是焦虑"}, {"num": 16, "title": "7~12岁体测解读主线", "content": "高龄重点：看水平、看差距、看潜力\n01\n课堂状态\n训练中的专注度、配合度、积极性\n02\n体育表现\n学校体育成绩、运动项目参与情况\n03\n任务完成\n训练任务的完成质量和进步速度\n04\n自信与同伴比较\n在团队中的自信程度和相对水平\n统一讲法：“XX方面目前处于XX水平，通过训练可以提升到XX”"}, {"num": 17, "title": "7~12岁重点项目示例", "content": "三个典型体测项目的解读方法\n4×10米折返跑\n看什么：速度 + 灵敏 + 心肺耐力\n怎么讲：折返跑综合反映快速移动和变向能力\n家长语言：“折返跑能看出孩子的速度和灵活性”\n1分钟跳绳\n看什么：协调 + 耐力 + 节奏感\n怎么讲：跳绳考验全身协调和持续运动能力\n家长语言：“跳绳能看出孩子的协调性和体能”\n台阶测试\n看什么：心肺耐力 + 恢复能力\n怎么讲：台阶测试反映有氧能力和恢复速度\n家长语言：“台阶测试能看出孩子的体能底子”\n统一提醒\n高龄可以讲“水平”和“差距”，但要用鼓励性语言，避免制造焦虑"}, {"num": 18, "title": "统一体测反馈骨架", "content": "六步法标准化反馈流程\n1\n①说明指标意义\n向家长解释每个指标代表什么\n➡\n2\n②呈现数据\n用体测数据客观呈现孩子现状\n➡\n3\n③分析原因\n分析数据背后的原因\n➡\n4\n④指出影响\n指出当前状况可能带来的影响\n➡\n5\n⑤给解决方案\n给出针对性的训练解决方案\n跳绳反馈示例\n● 指标意义：“跳绳是协调性和心肺耐力的重要指标”\n ● 呈现数据：\"1分钟跳了XX个，同龄平均是XX个\"\n ● 分析原因：\"主要在协调性和节奏感上还有提升空间\"\n ● 指出影响：\"这可能影响孩子体育成绩和运动自信\"\n ● 解决方案：\"建议通过体能跳绳课系统训练\"\n ● 展示案例：\"之前有个类似情况的孩子，训练3个月后从XX个提升到XX个\"\n❌ 不要这样讲：“你家孩子跳绳太差了，不练不行”\n制造焦虑 = 推远家长，用专业+鼓励的方式才能建立信任\n➡\n6\n⑥展示案例\n展示成功学员的训练效果案例"}, {"num": 19, "title": "感统怎么讲给家长听", "content": "把专业概念翻译成家长听得懂的话\n感统三步：信息输入 → 大脑整理 → 动作输出\n信息输入\n眼睛看、耳朵听、皮肤感觉、身体位置感知\n大脑整理\n大脑接收信息后进行分类、判断、发出指令\n动作输出\n身体根据指令做出正确的动作反应\n家长看到的 4 种表现\n● 好动不安、坐不住 —— 可能与前庭觉有关\n● 动作笨拙、不协调 —— 可能与本体觉有关\n● 怕碰触、抗拒某些材质 —— 可能与触觉有关\n● 注意力不集中、容易分心 —— 可能与感统整体有关\n正确表达方式\n“感统是孩子学习和运动的基础，通过运动训练可以很好地帮助发展”"}, {"num": 20, "title": "敏感期怎么讲才不焦虑", "content": "用专业化解焦虑，用引导替代推销\n正确讲法 3 条\n1. 敏感期是训练的“黄金窗口”，不是“最后期限”\n2. 错过敏感期不代表不能补，只是需要更多时间\n3. 现在开始就是最好的时机\n错误 vs 正确说法对比\n❌ “再不练就晚了！”\n✅ “现在正是训练的好时机”\n\n❌ “敏感期过了就没机会了”\n✅ “敏感期内训练效果会更好”\n\n❌ “别人家孩子都在练”\n✅ “每个孩子有自己的节奏”\n核心原则\n用“机会”替代“压力”，用“发展”替代“落后”\n家长信任来自专业，不是来自焦虑"}, {"num": 21, "title": "前庭觉、本体觉、触觉", "content": "三大感觉系统详解\n前庭觉\n平衡与空间感知\n关键词：平衡、方向、空间\n常见表现：晕车、好动、爱转圈\n家长语言：“孩子平衡差、老摔跤”\n本体觉\n身体控制与协调\n关键词：控制、力度、协调\n常见表现：动作粗鲁、力度掌握不好\n家长语言：“孩子动作笨、不知轻重”\n触觉\n触感与情绪反应\n关键词：触感、情绪、适应\n常见表现：怕碰触、挑食、抗拒材质\n家长语言：“孩子很敏感、怕摸”\n三大感觉系统互相影响，运动训练是同时促进感统发展的最佳方式"}, {"num": 22, "title": "低龄家长最关心什么", "content": "3~6岁家长的四大核心关注\n01\n安全\n训练环境是否安全、教练是否专业\n02\n兴趣\n孩子是否愿意来、会不会哭闹\n03\n基础发展\n运动能力是否正常、有没有落后\n04\n社交适应\n能不能和其他小朋友相处\n家长语言 4 条\n▶ “这么小练会不会受伤？”\n▶ “孩子不愿意来怎么办？”\n▶ “我家孩子运动能力正常吗？”\n▶ “能和其他小朋友一起玩吗？”\n统一结论\n低龄家长的核心诉求是“安心” —— 先解决安全和适应问题，再谈训练效果"}, {"num": 23, "title": "高龄家长最关心什么", "content": "7~12岁家长的四大核心关注\n01\n体育成绩\n学校体测能不能过关、能不能提升\n02\n身高管理\n能不能长高、体态好不好\n03\n运动技能\n能不能学会某项运动、有没有特长\n04\n自信心\n运动中能不能建立自信\n具体的话 4 条\n▶ “体测能不能过关？”\n▶ “练了能长高吗？”\n▶ “能不能学会打篮球？”\n▶ “孩子运动没自信怎么办？”\n统一结论\n高龄家长的核心诉求是“效果” —— 用数据和进步说话，给家长看得见的改变"}, {"num": 24, "title": "课程承接常见错误", "content": "4个错误及造成的后果\n1\n直接推课\n“建议您报我们的XX课”\n➡\n造成的结果\n家长感觉在推销，产生防备心理\n2\n忽略反馈\n教练讲完直接跳到报价\n➡\n造成的结果\n家长觉得没有被认真对待\n3\n过度承诺\n“练了肯定能提高”\n➡\n造成的结果\n期望落差大，后续投诉风险高\n4\n专业断层\n教练讲的专业销售接不住\n➡\n造成的结果\n家长对门店专业度产生怀疑\n错误承接的核心问题：没有让家长感受到“专业判断”，只感受到了“销售意图”"}, {"num": 25, "title": "正确的课程承接方式", "content": "判断 → 翻译 → 给路径\nSTEP 1\n判断\n听懂教练反馈，理解孩子的情况\n➡\nSTEP 2\n翻译\n用家长语言解释，让家长理解\n➡\nSTEP 3\n给路径\n给出清晰的训练建议和课程方案\n承接示例\n▶ 判断：教练反馈“协调性需要加强，下肢力量偏弱”\n▶ 翻译：“也就是说孩子在需要手脚配合的动作上会有些吃力，跑步跳跃时腿部力量还不够”\n▶ 给路径：“建议通过体能训练课来系统提升，先打好基础，再逐步加强专项”\n关键原则\n每一步都要让家长感受到“这是为孩子好”，而不是“想卖课”"}, {"num": 26, "title": "销售与教练协同节点", "content": "三个关键配合时刻\n01\n前采阶段\n销售了解家长需求和孩子情况\n传递给教练，让教练有针对性地观察\n02\n体验中观察\n教练在体验课中观察孩子表现\n销售同步观察家长反应和关注点\n03\n教练反馈后承接\n教练给出专业评估和建议\n销售用家长语言翻译并推荐课程\n最常见 3 个问题\n❌ 销售没有提前传递信息 —— 教练不知道家长关注什么\n❌ 教练反馈太专业 —— 家长听不懂，销售也接不住\n❌ 反馈后直接报价 —— 缺少翻译环节，家长感觉被推销"}, {"num": 27, "title": "双人配合示范", "content": "教练+顾问标准配合流程\n教练示范表达\n“XX今天整体表现不错，在XX方面有进步”\n“在XX方面还有提升空间，建议加强XX训练”\n“通过系统训练，XX方面是可以明显改善的”\n顾问承接表达\n“刚才教练提到的XX，简单来说就是...”\n“针对这个情况，我们建议...”\n“这门课正好能帮助孩子...”\n顾问最容易出错的 3 个地方\n❌ 重复教练的话 —— 应该翻译而不是复述\n❌ 急于报价 —— 应该先让家长理解价值\n❌ 打断教练反馈 —— 应该等教练说完再承接\n配合要点：教练讲“专业”，顾问讲“人话”，两者缺一不可"}, {"num": 28, "title": "高频异议处理（一）", "content": "标准化回应框架\n异议：“孩子还小”\nF —— 理解家长\n“您说得对，孩子确实还小，正是打基础的好时候”\n\nA —— 给出专业依据\n“3-6岁是运动基础发展的关键期，现在建立好的动作模式，以后学什么都快”\n\nB —— 强调利益\n“现在开始训练，孩子不仅运动能力强，专注力和自信心也会跟着提升”\n异议：“先回家练练”\nF —— 理解家长\n“理解您的想法，回家练也是一种方式”\n\nA —— 给出专业依据\n“不过运动训练需要专业指导和系统计划，自己练容易动作不标准”\n\nB —— 强调利益\n“来门店训练，教练会根据孩子情况制定方案，效果比自己练好很多”\n异议处理核心：先认同，再专业，最后给利益 —— 永远不要和家长对立"}, {"num": 29, "title": "高频异议处理（二）", "content": "标准化回应框架\n异议：“我们再看看”\nF —— 理解家长\n“没问题，多了解是对的，毕竟关系到孩子”\n\nA —— 给出专业依据\n“不过孩子的运动发展有最佳窗口期，现在开始训练效果最好”\n\nB —— 强调利益\n“可以先体验一下，看看孩子喜不喜欢，再做决定也不迟”\n异议：“你们是不是保证结果”\nF —— 理解家长\n“理解您的顾虑，您希望看到训练效果”\n\nA —— 给出专业依据\n“训练效果取决于孩子的参与度和配合度，我们会全力指导”\n\nB —— 强调利益\n“我们会定期体测反馈，让您看到孩子的每一步进步”\n不保证结果，但保证专业指导和持续反馈 —— 这才是负责任的态度"}, {"num": 30, "title": "演练评分标准", "content": "四个维度评估专业度\n1\n判断力\n能否准确识别孩子的情况和需求\n听教练反馈后能否快速理解\n2\n翻译力\n能否用家长语言解释专业概念\n让家长听得懂、能理解\n3\n承接力\n能否自然过渡到课程推荐\n不生硬、不推销\n4\n边界感\n能否守住销售的专业边界\n不越界、不乱承诺\n统一提醒\n评分不是“打分”，是帮助每个人找到提升方向\n四个维度缺一不可，任何一个短板都会影响家长体验\n目标是：每个人都能达到“独立接待+专业推荐”的标准"}, {"num": 31, "title": "每周演练与月度通关机制", "content": "让培训落地，让能力可复制\n每周演练 3 条\n1. 每周一次情景模拟演练（30分钟）\n2. 两人一组，轮流扮演销售和家长\n3. 店长/讲师现场点评，记录改进点\n月度通关 3 条\n1. 每月一次正式通关考核\n2. 按评分标准四维度打分\n3. 通关通过方可独立接待\n带教留痕流程\n▶ 演练记录表 → 记录每次演练的主题、表现、改进点\n▶ 通关记录表 → 记录每次通关的评分和结果\n▶ 成长档案 → 每位销售的成长轨迹和进步记录\n培训不是一次性的，而是持续的 —— 演练+通关+带教，三位一体"}, {"num": 32, "title": "收尾与行动要求", "content": "从今天开始，让专业成为习惯\n01\n熟记七大素质和家长语言翻译\n02\n掌握体测反馈六步法\n03\n练习课程承接三步（判断/翻译/给路径）\n04\n参加本周情景模拟演练\n05\n用 FAB 结构向一位家长做一次完整推荐\n“专业不是知道很多，而是能让家长感受到你的专业”"}];
let currentSlide = 0;

function escapeHtml(value) {
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function parseContent(text) {
  const lines = String(text || '').split('\n');
  let html = '';
  let inList = false;
  let listType = null;

  const flushList = () => {
    if (inList) {
      html += `</${listType}>`;
      inList = false;
      listType = null;
    }
  };

  for (let rawLine of lines) {
    const line = rawLine.trim();
    if (!line) {
      flushList();
      continue;
    }

    if (/^(\d{1,2}|[A-Z]|[♥☺↑★◆●▼→←<!~])$/.test(line)) {
      continue;
    }

    if (/^(\d{2}\s|STEP\s\d|F\d|F\s——)/.test(line)) {
      flushList();
      html += `<h3 class="slide-h3">${escapeHtml(line)}</h3>`;
      continue;
    }

    if (line.startsWith('●') || line.startsWith('•') || line.startsWith('-') || line.startsWith('✓') || line.startsWith('✗') || line.startsWith('▶') || line.startsWith('✔')) {
      if (!inList || listType !== 'ul') {
        flushList();
        html += '<ul class="slide-ul">';
        inList = true;
        listType = 'ul';
      }
      html += `<li>${escapeHtml(line.substring(1).trim())}</li>`;
      continue;
    }

    if (/^\d+\./.test(line)) {
      if (!inList || listType !== 'ol') {
        flushList();
        html += '<ol class="slide-ol">';
        inList = true;
        listType = 'ol';
      }
      html += `<li>${escapeHtml(line.replace(/^\d+\.\s*/, ''))}</li>`;
      continue;
    }

    if (line.startsWith('【') && line.includes('】')) {
      flushList();
      html += `<div class="slide-label">${escapeHtml(line)}</div>`;
      continue;
    }

    if (line.includes('：') && line.length < 40) {
      flushList();
      html += `<div class="key-point">${escapeHtml(line)}</div>`;
      continue;
    }

    flushList();
    html += `<p>${escapeHtml(line)}</p>`;
  }

  flushList();
  return html;
}

function renderSlideList() {
  const list = document.getElementById('slideList');
  list.innerHTML = SLIDES.map((slide, index) => `
    <div class="slide-item ${index === currentSlide ? 'active' : ''}" onclick="goToSlide(${index})">
      <span class="num">${escapeHtml(slide.num)}</span>
      <span class="title">${escapeHtml(slide.title)}</span>
    </div>
  `).join('');
}

function renderSlide() {
  const slide = SLIDES[currentSlide];
  document.getElementById('slideContent').innerHTML = `
    <div class="slide-header">
      <span class="slide-num">${escapeHtml(slide.num)} / ${SLIDES.length}</span>
      <h1>${escapeHtml(slide.title)}</h1>
    </div>
    <div class="slide-body">${parseContent(slide.content)}</div>
  `;
  document.getElementById('prevBtn').disabled = currentSlide === 0;
  document.getElementById('nextBtn').disabled = currentSlide === SLIDES.length - 1;
  renderSlideList();
}

function goToSlide(index) {
  currentSlide = index;
  renderSlide();
}

function prevSlide() {
  if (currentSlide > 0) {
    currentSlide--;
    renderSlide();
  }
}

function nextSlide() {
  if (currentSlide < SLIDES.length - 1) {
    currentSlide++;
    renderSlide();
  }
}

function switchTab(tab) {
  document.querySelectorAll('.tab-bar button').forEach(button => button.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.getElementById('ppt-panel').hidden = tab !== 'ppt';
  document.getElementById('script-panel').classList.toggle('active', tab === 'script');
  if (tab === 'script' && !window.scriptRendered) {
    renderScript();
    window.scriptRendered = true;
  }
}

