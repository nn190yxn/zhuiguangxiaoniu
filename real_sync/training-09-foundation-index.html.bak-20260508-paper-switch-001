const EXAM_POOL = [EXAM_DATA_A, EXAM_DATA_B];
let ACTIVE_EXAM = null;

function pickRandomExamPaper() {
  const idx = Math.floor(Math.random() * EXAM_POOL.length);
  const source = EXAM_POOL[idx];
  return JSON.parse(JSON.stringify(source));
}

let examAnswers = {};
let examSubmitted = false;

function renderExam() {
  if (!ACTIVE_EXAM) {
    ACTIVE_EXAM = pickRandomExamPaper();
  }
  const container = document.getElementById('examContainer');
  let html = '';

  // 考试说明
  html += `
    <div class="exam-intro">
      <h2>${ACTIVE_EXAM.title}</h2>
      <div class="exam-meta-row">
        <span>⏱ ${ACTIVE_EXAM.duration}分钟</span>
        <span>📝 满分${ACTIVE_EXAM.totalScore}分</span>
        <span>✅ ${ACTIVE_EXAM.passScore}分及格</span>
      </div>
    </div>
  `;

  // 按题型分组
  const sections = [
    {type:'choice', title:'第一部分：选择题（共20题，每题2分，共40分）', filter: q => q.type === 'choice'},
    {type:'judge', title:'第二部分：判断题（共10题，每题2分，共20分）', filter: q => q.type === 'judge'},
    {type:'text', title:'第三部分：简答题与情景题（共6题，共40分）', filter: q => q.type === 'text'}
  ];

  sections.forEach(section => {
    const questions = ACTIVE_EXAM.questions.filter(section.filter);
    if (questions.length === 0) return;

    html += `<div class="exam-section">`;
    html += `<div class="exam-section-title">${section.title}</div>`;

    questions.forEach((q, idx) => {
      html += `<div class="question-block" data-qid="${q.id}">`;
      html += `<div class="q-header">`;
      html += `<span class="q-num">${idx + 1}</span>`;
      html += `<span class="q-type">${q.type === 'choice' ? '选择题' : q.type === 'judge' ? '判断题' : '问答/情景题'}</span>`;
      html += `<span class="q-score">${q.score}分</span>`;
      html += `</div>`;
      html += `<div class="q-content">${escapeHtml(q.content).replace(/\n/g, '<br>')}</div>`;

      if (q.type === 'choice') {
        const letters = ['A', 'B', 'C', 'D'];
        html += `<div class="options-list">`;
        q.options.forEach((opt, i) => {
          html += `<div class="option-item" onclick="selectOption(${q.id}, '${letters[i]}')" data-opt="${letters[i]}">`;
          html += `<span class="opt-letter">${letters[i]}</span>`;
          html += `<span class="opt-text">${escapeHtml(opt)}</span>`;
          html += `</div>`;
        });
        html += `</div>`;
      } else if (q.type === 'judge') {
        html += `<div class="judge-options">`;
        html += `<div class="judge-option" onclick="selectJudge(${q.id}, 'V')" data-val="V">✓ 正确</div>`;
        html += `<div class="judge-option" onclick="selectJudge(${q.id}, 'X')" data-val="X">✗ 错误</div>`;
        html += `</div>`;
      } else {
        html += `<textarea class="answer-textarea" id="answer-${q.id}" placeholder="请输入您的答案..." oninput="saveTextAnswer(${q.id})"></textarea>`;
      }

      html += `</div>`;
    });

    html += `</div>`;
  });

  // 提交栏
  html += `
    <div class="exam-submit-bar">
      <button class="btn-submit-exam" id="submitBtn" onclick="submitExam()">提交试卷</button>
    </div>
  `;

  container.innerHTML = html;
}

function selectOption(qid, value) {
  if (examSubmitted) return;
  examAnswers[qid] = value;
  const block = document.querySelector(`.question-block[data-qid="${qid}"]`);
  block.querySelectorAll('.option-item').forEach(el => {
    el.classList.toggle('selected', el.dataset.opt === value);
  });
}

function selectJudge(qid, value) {
  if (examSubmitted) return;
  examAnswers[qid] = value;
  const block = document.querySelector(`.question-block[data-qid="${qid}"]`);
  block.querySelectorAll('.judge-option').forEach(el => {
    el.classList.toggle('selected', el.dataset.val === value);
  });
}

function saveTextAnswer(qid) {
  if (examSubmitted) return;
  const textarea = document.getElementById(`answer-${qid}`);
  if (textarea) {
    examAnswers[qid] = textarea.value;
  }
}

function submitExam() {
  if (examSubmitted) return;

  // 检查未答题
  const unanswered = ACTIVE_EXAM.questions.filter(q => !examAnswers[q.id] || (q.type === 'text' && !examAnswers[q.id].trim()));
  if (unanswered.length > 0) {
    if (!confirm(`您还有 ${unanswered.length} 道题未作答，确定要提交吗？`)) {
      return;
    }
  }

  if (!confirm('确认提交试卷？提交后不可修改。')) {
    return;
  }

  examSubmitted = true;
  document.getElementById('submitBtn').disabled = true;
  document.getElementById('submitBtn').textContent = '已提交';

  // 收集所有文本题答案
  ACTIVE_EXAM.questions.filter(q => q.type === 'text').forEach(q => {
    const textarea = document.getElementById(`answer-${q.id}`);
    if (textarea && !examAnswers[q.id]) {
      examAnswers[q.id] = textarea.value;
    }
  });

  // 自动评分
  const result = gradeExam();
  showResult(result);
}

function gradeExam() {
  let totalScore = 0;
  let maxScore = 0;
  const details = [];

  ACTIVE_EXAM.questions.forEach(q => {
    maxScore += q.score;
    const userAnswer = examAnswers[q.id] || '';
    let score = 0;
    let isCorrect = false;

    if (q.type === 'choice' || q.type === 'judge') {
      isCorrect = userAnswer === q.answer;
      score = isCorrect ? q.score : 0;
    } else if (q.type === 'text') {
      // 关键词匹配评分
      if (q.keywords && userAnswer.trim()) {
        const answerLower = userAnswer.toLowerCase();
        const matched = q.keywords.filter(kw => answerLower.includes(kw.toLowerCase()));
        const matchRatio = matched.length / q.keywords.length;
        score = Math.round(q.score * Math.min(matchRatio * 1.2, 1)); // 1.2倍容错
        isCorrect = matchRatio >= 0.5;
      }
    }

    totalScore += score;
    details.push({
      question: q,
      userAnswer,
      correctAnswer: q.answer,
      score,
      isCorrect
    });
  });

  return {
    totalScore,
    maxScore,
    passScore: ACTIVE_EXAM.passScore,
    isPassed: totalScore >= ACTIVE_EXAM.passScore,
    details
  };
}

function showResult(result) {
  const container = document.getElementById('examContainer');
  const statusClass = result.isPassed ? 'pass' : 'fail';
  const statusText = result.isPassed ? '🎉 恭喜通关！' : '未通过，请继续学习';

  let html = `
    <div class="exam-result">
      <div class="result-score-circle ${statusClass}">
        <div class="score-num">${result.totalScore}</div>
        <div class="score-label">/ ${result.maxScore}</div>
      </div>
      <div class="result-status ${statusClass}">${statusText}</div>
      <div class="result-detail">
        及格分 ${result.passScore} 分 · ${result.isPassed ? '已达到及格线' : '未达到及格线，请复习后重考'}
      </div>
    </div>

    <div class="review-section">
      <h3>📋 答题详情</h3>
  `;

  result.details.forEach((d, idx) => {
    const cls = d.isCorrect ? 'correct' : 'wrong';
    const qType = d.question.type === 'choice' ? '选择题' : d.question.type === 'judge' ? '判断题' : '问答/情景题';
    let answerHtml = '';

    if (d.question.type === 'choice') {
      answerHtml = `<span class="${d.isCorrect ? 'correct' : 'your'}">你的答案：${d.userAnswer || '未作答'}</span> · <span class="correct">正确答案：${d.correctAnswer}</span>`;
    } else if (d.question.type === 'judge') {
      const userText = d.userAnswer === 'V' ? '正确' : d.userAnswer === 'X' ? '错误' : '未作答';
      const correctText = d.correctAnswer === 'V' ? '正确' : '错误';
      answerHtml = `<span class="${d.isCorrect ? 'correct' : 'your'}">你的答案：${userText}</span> · <span class="correct">正确答案：${correctText}</span>`;
    } else {
      answerHtml = `<div style="margin-top:8px;padding:10px;background:#f9f7f4;border-radius:8px;font-size:13px;">你的回答：${escapeHtml(d.userAnswer) || '未作答'}</div>`;
    }

    html += `
      <div class="review-item ${cls}">
        <div class="review-q">[${qType}] ${idx + 1}. ${escapeHtml(d.question.content.substring(0, 50))}${d.question.content.length > 50 ? '...' : ''} （${d.score}/${d.question.score}分）</div>
        <div class="review-answer">${answerHtml}</div>
      </div>
    `;
  });

  html += `</div>`;
  container.innerHTML = html;

  // 滚动到顶部
  window.scrollTo({top: 0, behavior: 'smooth'});
}

// 修改switchTab函数，支持exam tab
const originalSwitchTab = switchTab;
switchTab = function(tab) {
  document.querySelectorAll('.tab-bar button').forEach(button => button.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.getElementById('ppt-panel').hidden = tab !== 'ppt';
  document.getElementById('script-panel').classList.toggle('active', tab === 'script');
  document.getElementById('exam-panel').hidden = tab !== 'exam';
  if (tab === 'script' && !window.scriptRendered) {
    renderScript();
    window.scriptRendered = true;
  }
  if (tab === 'exam' && !window.examRendered) {
    renderExam();
    window.examRendered = true;
  }
};

