.container {
  min-height: 100vh;
  background: #f5f3f0;
  padding: 20rpx;
}

.header {
  padding: 30rpx 20rpx 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  position: relative;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.dimension-tag {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
}

.dimension-qa {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.dimension-knowledge {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.dimension-feedback {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.dimension-deal {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.record-date {
  font-size: 24rpx;
  color: #999;
}

.record-score {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.score-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #fff;
}

.score-excellent {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
}

.score-good {
  background: linear-gradient(135deg, #1890ff 0%, #69c0ff 100%);
}

.score-pass {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
}

.score-fail {
  background: linear-gradient(135deg, #f5222d 0%, #ff7875 100%);
}

.score-default {
  background: linear-gradient(135deg, #999 0%, #bfbfbf 100%);
}

.score-value {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1;
}

.score-label {
  font-size: 22rpx;
  opacity: 0.9;
}

.score-info {
  flex: 1;
}

.level-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.level-excellent { color: #52c41a; }
.level-good { color: #1890ff; }
.level-pass { color: #faad14; }
.level-fail { color: #f5222d; }

.intent {
  font-size: 26rpx;
  color: #666;
}

.intent-high { color: #52c41a; font-weight: 500; }
.intent-medium { color: #faad14; font-weight: 500; }
.intent-low { color: #f5222d; font-weight: 500; }

.record-feedback {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.record-arrow {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: #ccc;
}

.load-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

.load-more text {
  color: #ff6b35;
}