page {
  background: #f5f3f0;
}

.survey-container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 已提交提示 */
.submitted-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-top: 100rpx;
}
.hint-icon {
  width: 100rpx;
  height: 100rpx;
  background: #4caf50;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-bottom: 30rpx;
}
.hint-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 40rpx;
}
.hint-btn {
  background: #ff6b35;
  color: #fff;
  border-radius: 40rpx;
  padding: 0 60rpx;
  font-size: 28rpx;
}

/* 问卷头部 */
.survey-header {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
}
.survey-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}
.survey-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}
.survey-meta {
  display: flex;
  gap: 12rpx;
}
.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #fff3e0;
  color: #ff6b35;
}
.meta-tag.anonymous {
  background: #e8f5e9;
  color: #4caf50;
}

/* 校区选择 */
.campus-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.section-label.required::before {
  content: '* ';
  color: #f44336;
}
.campus-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.campus-value .selected {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 500;
}
.campus-value .placeholder {
  font-size: 28rpx;
  color: #999;
}
.arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 弹窗选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.picker-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}
.picker-cancel {
  font-size: 28rpx;
  color: #999;
}
.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.picker-confirm {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 600;
}
.picker-view {
  height: 400rpx;
}
.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 50px;
  font-size: 28rpx;
  color: #333;
}

/* 分区 */
.section-group {
  margin-bottom: 24rpx;
}
.section-title-bar {
  font-size: 30rpx;
  font-weight: 700;
  color: #ff6b35;
  padding: 20rpx 10rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid #ff6b35;
}

/* 题目卡片 */
.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 16rpx;
}
.question-header {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 24rpx;
}
.required-mark {
  color: #f44336;
  font-size: 28rpx;
  flex-shrink: 0;
}
.question-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.5;
}

/* 选项列表 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.option-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #faf9f8;
  border: 2rpx solid transparent;
}
.option-item.active {
  background: #fff3e0;
  border-color: #ff6b35;
}
.option-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.option-item.active .option-radio {
  border-color: #ff6b35;
}
.radio-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff6b35;
}
.option-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  border: 3rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.option-item.active .option-checkbox {
  border-color: #ff6b35;
  background: #ff6b35;
}
.check-mark {
  color: #fff;
  font-size: 24rpx;
}
.option-text {
  font-size: 28rpx;
  color: #333;
}

/* 评分星星 */
.rating-stars {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.star-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  background: #faf9f8;
  min-width: 100rpx;
}
.star-item.active {
  background: #fff3e0;
}
.star-icon {
  font-size: 44rpx;
  color: #ddd;
}
.star-item.active .star-icon {
  color: #ff6b35;
}
.star-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* NPS */
.nps-scale {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.nps-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 10rpx;
  background: #faf9f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
}
.nps-item.active {
  background: #ff6b35;
  color: #fff;
}
.nps-labels {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #999;
}

/* 文字回答 */
.text-answer {
  position: relative;
}
.text-input {
  width: 100%;
  min-height: 120rpx;
  background: #faf9f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}
.submit-btn {
  background: #ff6b35;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border: none;
}
.submit-btn.disabled {
  opacity: 0.6;
}
