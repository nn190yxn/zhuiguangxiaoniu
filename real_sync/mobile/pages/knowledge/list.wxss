.search-bar {
  margin: 16px;
  background: #ffffff;
  border-radius: 24px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
}

.search-bar input {
  flex: 1;
  font-size: 14px;
  border: none;
  outline: none;
}

.category-tabs {
  padding: 0 16px;
  white-space: nowrap;
  margin-bottom: 16px;
}

.tab-item {
  display: inline-block;
  padding: 8px 16px;
  font-size: 13px;
  color: #6b625c;
  background: #ffffff;
  border-radius: 20px;
  margin-right: 8px;
}

.tab-item.active {
  background: #ff6b35;
  color: #ffffff;
}

.knowledge-list {
  padding: 0 16px;
}

.knowledge-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  display: flex;
  gap: 12px;
}

.knowledge-cover {
  width: 64px;
  height: 64px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cover-icon {
  font-size: 28px;
}

.knowledge-info {
  flex: 1;
  overflow: hidden;
}

.knowledge-title {
  font-size: 15px;
  font-weight: 600;
  color: #1f1a17;
  margin-bottom: 4px;
}

.knowledge-summary {
  font-size: 12px;
  color: #9a958e;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.knowledge-tags {
  display: flex;
  gap: 6px;
}

.tag {
  padding: 2px 8px;
  background: #f5f3f0;
  border-radius: 8px;
  font-size: 11px;
  color: #6b625c;
}

.tag.filter {
  background: #e8f5e9;
  color: #4caf50;
}

.expanded-filters {
  background: #ffffff;
  padding: 12px 16px;
  margin: 0 16px 12px;
  border-radius: 12px;
}

.filter-section {
  margin-bottom: 12px;
}

.filter-section:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 12px;
  color: #9a958e;
  margin-bottom: 8px;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-tag {
  display: inline-block;
  padding: 6px 14px;
  font-size: 13px;
  color: #6b625c;
  background: #f5f3f0;
  border-radius: 16px;
  margin-right: 8px;
}

.filter-tag.active {
  background: #ff6b35;
  color: #ffffff;
}

.knowledge-status {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 12px;
  color: #9a958e;
}

.status-text.completed {
  color: #4caf50;
}

.empty, .loading {
  text-align: center;
  padding: 60px 0;
  color: #9a958e;
}