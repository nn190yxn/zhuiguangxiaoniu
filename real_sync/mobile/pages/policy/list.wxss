.container {
  min-height: 100vh;
  background: #f5f3f0;
}

.search-bar {
  padding: 12px 16px;
  background: white;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input {
  width: 100%;
  height: 40px;
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 20px;
  padding: 0 16px;
  font-size: 14px;
  background: #f5f3f0;
  box-sizing: border-box;
}

.search-input:focus {
  border-color: #ff6b35;
  background: white;
}

.tabs {
  display: flex;
  gap: 8px;
  padding: 12px 16px;
  background: white;
  border-bottom: 1px solid rgba(0,0,0,0.04);
  white-space: nowrap;
}

.tab {
  flex-shrink: 0;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
  background: #f5f3f0;
  color: #6b625c;
}

.tab.active {
  background: #ff6b35;
  color: white;
}

.policy-list {
  padding: 16px;
}

.policy-card {
  background: white;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
}

.policy-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 8px;
}

.policy-title {
  font-size: 15px;
  font-weight: 600;
  color: #1f1a17;
  line-height: 1.4;
  flex: 1;
}

.policy-badge {
  flex-shrink: 0;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  background: rgba(255,107,53,0.1);
  color: #ff6b35;
}

.policy-meta {
  display: flex;
  gap: 12px;
  font-size: 12px;
  color: #6b625c;
  margin-bottom: 12px;
}

.policy-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid rgba(0,0,0,0.04);
}

.policy-time {
  font-size: 12px;
  color: #6b625c;
}

.policy-btn {
  padding: 6px 16px;
  border-radius: 16px;
  font-size: 13px;
  font-weight: 600;
  background: rgba(255,107,53,0.1);
  color: #ff6b35;
}

.policy-btn.btn-confirm {
  background: #ff6b35;
  color: white;
}

.empty {
  text-align: center;
  padding: 60px 20px;
  color: #6b625c;
}

.loading {
  text-align: center;
  padding: 20px;
  color: #6b625c;
}