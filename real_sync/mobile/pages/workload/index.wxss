.container{min-height:100vh;background:#f5f3f0;padding:16px 16px 96px;box-sizing:border-box}.hero{background:linear-gradient(135deg,#ff6b35,#ff9a5f);border-radius:22px;padding:20px;color:#fff;margin-bottom:14px;box-shadow:0 8px 20px rgba(255,107,53,.2)}.hero-title{font-size:22px;font-weight:800;margin-bottom:6px}.hero-sub{font-size:13px;opacity:.92;line-height:1.6}.user-pill{display:inline-flex;margin-top:10px;background:rgba(255,255,255,.2);border-radius:999px;padding:4px 10px;font-size:12px;font-weight:700}.card{background:#fff;border-radius:18px;padding:16px;margin-bottom:14px;border:1px solid rgba(0,0,0,.06);box-shadow:0 4px 14px rgba(0,0,0,.04)}.draft-tip{margin-bottom:12px;padding:10px 12px;border-radius:12px;background:#fff8e8;color:#8a5a00;font-size:12px;line-height:1.7}.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}.field{margin-bottom:12px}.label{display:block;font-size:12px;color:#6b625c;font-weight:700;margin-bottom:6px}.picker-value,.input,.textarea{background:#fafafa;border:1px solid rgba(0,0,0,.08);border-radius:12px;padding:11px 12px;font-size:15px;box-sizing:border-box}.input{width:100%}.textarea{width:100%;height:84px}.status{font-size:13px;color:#6b625c;line-height:1.6}.status.ok{color:#087443}.status.err{color:#b42318}.metric{padding:12px 0;border-bottom:1px solid rgba(0,0,0,.06)}.metric:last-child{border-bottom:none}.metric-main{display:grid;grid-template-columns:1fr 112px;gap:12px;align-items:center}.metric-name{font-size:14px;font-weight:750;color:#1f1a17}.metric-meta{font-size:11px;color:#6b625c;margin-top:3px}.metric-input{background:#fff7ed;border:1px solid rgba(255,107,53,.2);border-radius:12px;padding:10px;text-align:center;color:#ff6b35;font-weight:800}.evidence-box{margin-top:10px;padding:10px 12px;border:1px dashed rgba(255,107,53,.35);border-radius:14px;background:#fff7f2}.evidence-head{display:flex;justify-content:space-between;align-items:center;gap:8px}.evidence-title{font-size:12px;font-weight:800;color:#ff6b35}.evidence-tip{font-size:11px;color:#6b625c;line-height:1.6;margin-top:6px}.evidence-btn{margin-top:10px;border-radius:999px;background:#ff6b35;color:#fff;font-size:12px;font-weight:800;line-height:1;padding:10px 14px}.evidence-list{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-top:10px}.evidence-item{overflow:hidden;border-radius:12px;background:#fff;border:1px solid rgba(0,0,0,.06)}.evidence-image{width:100%;height:88px;background:#f0ece8}.evidence-name{padding:6px 8px;font-size:10px;color:#6b625c;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.evidence-card-actions{display:flex;gap:6px;padding:0 8px 8px}.evidence-mini-btn{flex:1;margin:0;border-radius:10px;background:#f5f3f0;color:#1f1a17;font-size:10px;line-height:1.2;padding:6px 8px}.evidence-mini-btn.danger{background:#fff1f3;color:#b42318}.evidence-empty{font-size:11px;color:#6b625c;margin-top:10px}.empty{text-align:center;color:#6b625c;padding:28px 0}.actions{position:fixed;left:0;right:0;bottom:0;background:#fff;border-top:1px solid rgba(0,0,0,.08);padding:10px 16px calc(10px + env(safe-area-inset-bottom));display:flex;gap:10px}.btn{flex:1;border-radius:14px;padding:12px;font-size:15px;font-weight:800}.btn.secondary{background:#f1eee9;color:#1f1a17}.btn.primary{background:#ff6b35;color:#fff}
